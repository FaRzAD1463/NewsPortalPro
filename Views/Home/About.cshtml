@{
    ViewData["Title"] = "আমাদের সম্পর্কে";
}

<div class="pb-page-container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="article-main-title mb-4">আমাদের সম্পর্কে</h1>

            <div class="article-body">
                <p>
                    নিউজপোর্টাল প্রো একটি স্বাধীন ডিজিটাল সংবাদ মাধ্যম, যা
                    বাংলাদেশ ও বিশ্বের গুরুত্বপূর্ণ ঘটনাবলী নির্ভুল, নিরপেক্ষ ও
                    সময়োপযোগীভাবে পাঠকদের কাছে পৌঁছে দেওয়ার লক্ষ্যে কাজ করে
                    যাচ্ছে। আমরা বিশ্বাস করি, একটি সুস্থ গণতন্ত্রের জন্য
                    নির্ভরযোগ্য সাংবাদিকতা অপরিহার্য।
                </p>

                <h2>আমাদের লক্ষ্য</h2>
                <p>
                    জাতীয়, আন্তর্জাতিক, রাজনীতি, অর্থনীতি, খেলাধুলা, বিনোদন,
                    প্রযুক্তি ও স্বাস্থ্য সংক্রান্ত সংবাদ দ্রুত ও তথ্যবহুলভাবে
                    উপস্থাপন করাই আমাদের মূল লক্ষ্য। আমরা প্রতিটি প্রতিবেদন
                    যাচাই-বাছাই করে প্রকাশ করার চেষ্টা করি, যাতে পাঠকরা সঠিক
                    তথ্যের ভিত্তিতে নিজস্ব মতামত গঠন করতে পারেন।
                </p>

                <h2>আমাদের নীতিমালা</h2>
                <p>
                    আমরা সাংবাদিকতার মৌলিক নীতি — সত্যতা, নিরপেক্ষতা,
                    জবাবদিহিতা ও স্বচ্ছতা — অনুসরণ করে চলি। কোনো প্রতিবেদনে
                    ভুল তথ্য প্রকাশিত হলে আমরা তা দ্রুত সংশোধন করার প্রতিশ্রুতি
                    দিচ্ছি।
                </p>

                <h2>যোগাযোগ</h2>
                <p>
                    আপনার মতামত, পরামর্শ বা অভিযোগ থাকলে আমাদের
                    <a href="/Contact">যোগাযোগ পাতা</a> থেকে বার্তা পাঠাতে
                    পারেন, অথবা সরাসরি ইমেইল করতে পারেন:
                    <strong>info@newsportalpro.com</strong>
                </p>
            </div>
        </div>
    </div>
</div>