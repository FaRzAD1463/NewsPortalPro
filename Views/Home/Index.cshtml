@model HomeViewModel
@{
    ViewData["Title"] = "হোম - নিউজপোর্টাল প্রো";
}

<!-- ══ HERO SECTION ══════════════════════════════════════ -->
<section class="hero-section py-3">
    <div class="container-fluid px-4">
        <div class="row g-3">

            <!-- Main Lead Story -->
            <div class="col-lg-6">
                @if (Model.FeaturedNews.Any())
                {
                    var lead = Model.FeaturedNews[0];
                    <div class="lead-story position-relative overflow-hidden rounded">
                        <a href="/news/@lead.Slug">
                            <img src="@(lead.FeaturedImage ?? "/images/placeholder.jpg")"
                                 alt="@lead.Title"
                                 class="lead-story-img w-100" loading="lazy" />
                        </a>
                        <div class="lead-story-overlay">
                            <span class="category-badge mb-2 d-inline-block"
                                  style="background:@lead.CategoryColor">
                                @lead.CategoryName
                            </span>
                            <h2 class="lead-title">
                                <a href="/news/@lead.Slug" class="text-white">@lead.Title</a>
                            </h2>
                            <p class="text-white-50 small d-none d-md-block">@lead.Summary</p>
                            <div class="text-white-50 small">
                                <i class="bi bi-clock me-1"></i>
                                @lead.PublishedAt?.ToString("dd MMM yyyy")
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Secondary stories grid -->
            <div class="col-lg-3">
                @foreach (var news in Model.FeaturedNews.Skip(1).Take(2))
                {
                    <div class="secondary-story position-relative overflow-hidden rounded mb-3">
                        <a href="/news/@news.Slug">
                            <img src="@(news.FeaturedImage ?? "/images/placeholder.jpg")"
                                 alt="@news.Title"
                                 class="secondary-story-img w-100" loading="lazy" />
                        </a>
                        <div class="secondary-story-overlay">
                            <span class="category-badge small mb-1 d-inline-block"
                                  style="background:@news.CategoryColor">
                                @news.CategoryName
                            </span>
                            <h6 class="text-white mb-0">
                                <a href="/news/@news.Slug" class="text-white">@news.Title</a>
                            </h6>
                        </div>
                    </div>
                }
            </div>

            <!-- Right sidebar stories -->
            <div class="col-lg-3">
                <div class="right-stories">
                    @foreach (var news in Model.FeaturedNews.Skip(3).Take(4))
                    {
                        <div class="right-story-item d-flex gap-2 mb-3 pb-3 border-bottom">
                            <img src="@(news.FeaturedImage ?? "/images/placeholder.jpg")"
                                 alt="@news.Title"
                                 class="right-story-thumb rounded flex-shrink-0"
                                 loading="lazy" />
                            <div>
                                <span class="category-badge small"
                                      style="background:@news.CategoryColor">
                                    @news.CategoryName
                                </span>
                                <h6 class="mt-1 mb-1 small fw-semibold">
                                    <a href="/news/@news.Slug" class="text-dark">@news.Title</a>
                                </h6>
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>
                                    @news.PublishedAt?.ToString("dd MMM")
                                </small>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ══ MAIN CONTENT ══════════════════════════════════════ -->
<div class="container-fluid px-4 mt-2">
    <div class="row g-4">

        <!-- Left: Main Feed -->
        <div class="col-lg-8 col-xl-9">

            <!-- Latest News -->
            <section class="news-section mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="section-title">সর্বশেষ সংবাদ</h2>
                    <a href="/news" class="small text-primary">আরও দেখুন →</a>
                </div>

                <div class="row g-4" id="latest-news-container">
                    @foreach (var news in Model.LatestNews)
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            @await Html.PartialAsync("_NewsCard", news)
                        </div>
                    }
                </div>

                <div class="text-center mt-3" id="infinite-scroll-trigger">
                    <div id="loading-spinner" class="d-none">
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    </div>
                    <button id="load-more-btn"
                            class="btn btn-outline-secondary btn-sm px-4">
                        আরও দেখুন
                    </button>
                </div>
            </section>

            <!-- Category blocks -->
            @foreach (var block in Model.CategoryNewsBlocks)
            {
                var cat = block.Value.Category;
                var catNews = block.Value.News;
                if (!catNews.Any()) continue;

                <section class="news-section mb-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="section-title"
                            style="border-bottom-color:@cat.ColorCode">
                            <a href="/category/@cat.Slug"
                               style="color:@cat.ColorCode"
                               class="text-decoration-none">@cat.Name</a>
                        </h2>
                        <a href="/category/@cat.Slug"
                           class="small text-decoration-none"
                           style="color:@cat.ColorCode">আরও দেখুন →</a>
                    </div>

                    <div class="row g-4">
                        <!-- Lead story -->
                        <div class="col-md-5">
                            <div class="pb-news-card pb-news-card-lead">
                                <a href="/news/@catNews[0].Slug"
                                   class="pb-card-img-link">
                                    <div class="pb-card-img-wrapper">
                                        <img src="@(catNews[0].FeaturedImage ?? "/images/placeholder.jpg")"
                                             alt="@catNews[0].Title"
                                             class="pb-card-img" loading="lazy" />
                                    </div>
                                </a>
                                <div class="pb-card-body">
                                    <a href="/category/@cat.Slug"
                                       class="pb-card-category"
                                       style="color:@cat.ColorCode">@cat.Name</a>
                                    <h3 class="pb-card-title">
                                        <a href="/news/@catNews[0].Slug">@catNews[0].Title</a>
                                    </h3>
                                    <p class="pb-card-summary">@catNews[0].Summary</p>
                                    <div class="pb-card-meta">
                                        <span class="pb-card-time">
                                            <i class="bi bi-clock me-1"></i>
                                            @catNews[0].PublishedAt?.ToString("dd MMM yyyy")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- List stories -->
                        <div class="col-md-7">
                            @foreach (var n in catNews.Skip(1).Take(4))
                            {
                                <div class="pb-news-card-horizontal">
                                    <a href="/news/@n.Slug"
                                       class="pb-card-img-link">
                                        <div class="pb-card-img-wrapper">
                                            <img src="@(n.FeaturedImage ?? "/images/placeholder.jpg")"
                                                 alt="@n.Title"
                                                 class="pb-card-img" loading="lazy" />
                                        </div>
                                    </a>
                                    <div class="pb-card-body flex-grow-1">
                                        <h3 class="pb-card-title">
                                            <a href="/news/@n.Slug">@n.Title</a>
                                        </h3>
                                        <div class="pb-card-meta mt-1">
                                            <span class="pb-card-time">
                                                <i class="bi bi-clock me-1"></i>
                                                @n.PublishedAt?.ToString("dd MMM")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </section>
            }

        </div>

        <!-- Right: Sidebar -->
        <div class="col-lg-4 col-xl-3">
            <div class="sticky-sidebar">

                <!-- Trending -->
                <div class="sidebar-widget mb-4">
                    <h5 class="widget-title">
                        <i class="bi bi-fire text-danger me-2"></i>সর্বাধিক পঠিত
                    </h5>
                    @foreach (var (news, i) in Model.TrendingNews
                                        .Select((n, i) => (n, i + 1)).Take(7))
                    {
                        <div class="d-flex gap-2 mb-3 pb-3 border-bottom">
                            <span class="trending-num fw-bold text-muted">@i</span>
                            <div>
                                <h6 class="mb-1 small">
                                    <a href="/news/@news.Slug" class="text-dark text-decoration-none">
                                        @news.Title
                                    </a>
                                </h6>
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>
                                    @news.PublishedAt?.ToString("dd MMM")
                                </small>
                            </div>
                        </div>
                    }
                </div>

                <!-- Ads -->
                @foreach (var ad in Model.SidebarAds.Take(2))
                {
                    <div class="sidebar-widget mb-4 text-center">
                        @if (!string.IsNullOrEmpty(ad.HtmlCode))
                        {
                            @Html.Raw(ad.HtmlCode)
                        }
                        else if (!string.IsNullOrEmpty(ad.ImageUrl))
                        {
                            <a href="@ad.TargetUrl" target="_blank">
                                <img src="@ad.ImageUrl" alt="@ad.Title"
                                     class="img-fluid rounded" />
                            </a>
                        }
                    </div>
                }

                <!-- Newsletter -->
                <div class="sidebar-widget mb-4">
                    <h5 class="widget-title">নিউজলেটার</h5>
                    <p class="small text-muted">সর্বশেষ সংবাদ ইনবক্সে পান</p>
                    <div class="input-group input-group-sm">
                        <input type="email" id="newsletter-email"
                               class="form-control"
                               placeholder="আপনার ইমেইল" />
                        <button class="btn btn-primary"
                                onclick="subscribeNewsletter()">
                            সাবস্ক্রাইব
                        </button>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Load mega menu news on hover
            $('.dropdown-hover').on('mouseenter', function () {
                const slug = $(this).find('.nav-link-custom').attr('href').replace('/category/', '');
                const container = $(`#mega-news-${slug}`);
                if (container.length && container.data('loaded') !== true) {
                    container.data('loaded', true);
                    fetch(`/api/news?categorySlug=${slug}&pageSize=4&page=1`)
                        .then(r => r.json())
                        .then(data => {
                            if (!data.items || data.items.length === 0) {
                                container.html('<p class="text-muted small p-3">কোনো সংবাদ নেই</p>');
                                return;
                            }
                            let html = '<div class="row g-2">';
                            data.items.forEach(n => {
                                html += `
                                <div class="col-6">
                                    <div class="d-flex gap-2">
                                        <img src="${n.featuredImage || '/images/placeholder.jpg'}"
                                             class="rounded flex-shrink-0"
                                             style="width:70px;height:52px;object-fit:cover"
                                             loading="lazy" />
                                        <div>
                                            <a href="/news/${n.slug}"
                                               class="small text-dark text-decoration-none fw-medium
                                                      d-block"
                                               style="-webkit-line-clamp:3;display:-webkit-box;
                                                      -webkit-box-orient:vertical;overflow:hidden">
                                                ${n.title}
                                            </a>
                                            <small class="text-muted">
                                                ${n.publishedAt ? new Date(n.publishedAt)
                                                    .toLocaleDateString('bn-BD') : ''}
                                            </small>
                                        </div>
                                    </div>
                                </div>`;
                            });
                            html += '</div>';
                            html += `<div class="mt-2 text-end">
                                <a href="/category/${slug}"
                                   class="small text-primary text-decoration-none">
                                    আরও দেখুন →
                                </a>
                            </div>`;
                            container.html(html);
                        })
                        .catch(() => container.html(''));
                }
            });

            // Infinite scroll
            let currentPage = 2;
            let isLoading = false;

            $('#load-more-btn').on('click', loadMoreNews);

            const observer = new IntersectionObserver(entries => {
                if (entries[0].isIntersecting && !isLoading) loadMoreNews();
            }, { threshold: 0.1 });

            const trigger = document.getElementById('infinite-scroll-trigger');
            if (trigger) observer.observe(trigger);

            async function loadMoreNews() {
                if (isLoading) return;
                isLoading = true;
                $('#load-more-btn').hide();
                $('#loading-spinner').removeClass('d-none');

                try {
                    const res = await fetch(`/api/news?page=${currentPage}&pageSize=9`);
                    const data = await res.json();
                    if (data.items && data.items.length > 0) {
                        data.items.forEach(n => {
                            $('#latest-news-container').append(`
                                <div class="col-6 col-md-4 col-lg-3">
                                    <div class="news-card card h-100 border-0 shadow-sm">
                                        <a href="/news/${n.slug}">
                                            <img src="${n.featuredImage || '/images/placeholder.jpg'}"
                                                 class="card-img-top"
                                                 alt="${n.title}" loading="lazy"
                                                 style="height:180px;object-fit:cover" />
                                        </a>
                                        <div class="card-body p-3">
                                            <span class="category-badge small"
                                                  style="background:${n.categoryColor || '#6c757d'}">
                                                ${n.categoryName}
                                            </span>
                                            <h6 class="card-title mt-2 small fw-semibold">
                                                <a href="/news/${n.slug}"
                                                   class="text-dark text-decoration-none">
                                                    ${n.title}
                                                </a>
                                            </h6>
                                            <small class="text-muted">
                                                <i class="bi bi-clock me-1"></i>
                                                ${n.publishedAt ? new Date(n.publishedAt)
                                                    .toLocaleDateString('bn-BD') : ''}
                                            </small>
                                        </div>
                                    </div>
                                </div>`);
                        });
                        currentPage++;
                        if (currentPage <= data.totalPages) $('#load-more-btn').show();
                    }
                } catch(e) { console.error(e); }
                finally {
                    isLoading = false;
                    $('#loading-spinner').addClass('d-none');
                }
            }

            function subscribeNewsletter() {
                const email = $('#newsletter-email').val();
                if (!email) return;
                fetch('/api/newsletter/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                }).then(r => r.json()).then(d => {
                    if (d.success) toastr.success('সাবস্ক্রিপশন সফল!');
                    else toastr.error(d.message);
                });
            }
        });
    </script>
}