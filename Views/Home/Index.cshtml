@using NewsPortalPro.DTOs
@using NewsPortalPro.Models
@model NewsPortalPro.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "হোম";
}

<div class="pb-home-wrapper">
    <div class="pb-page-container">

        <!-- ══ HERO / FEATURED ══════════════════════════════ -->
        @if (Model.FeaturedNews.Any())
        {
            <section class="pb-hero-section mt-3">
                <div class="row g-2">
                    <div class="col-md-6 col-lg-5">
                        @{
                            var hero = Model.FeaturedNews[0];
                        }
                        <div class="pb-hero-lead position-relative overflow-hidden">
                            <a href="/news/@hero.Slug">
                                <img src="@(hero.FeaturedImage ?? "/images/placeholder.jpg")"
                                     alt="@hero.Title"
                                     class="pb-hero-lead-img"
                                     loading="eager"
                                     onerror="this.src='/images/placeholder.jpg'" />
                            </a>
                            <div class="pb-hero-overlay">
                                <a href="/category/@hero.CategorySlug"
                                   class="pb-hero-cat-tag"
                                   style="background:@(hero.CategoryColor ?? "#c0392b")">
                                    @hero.CategoryName
                                </a>

                                <h2 class="pb-hero-title">
                                    <a href="/news/@hero.Slug"
                                       class="text-white text-decoration-none">
                                        @hero.Title
                                    </a>
                                </h2>

                                <p class="pb-hero-summary">@hero.Summary</p>

                            </div>


                        </div>

                    </div>

                    <div class="col-md-6 col-lg-7">
                        <div class="row g-2 h-100">
                            @foreach (var n in Model.FeaturedNews.Skip(1).Take(4))
                            {
                                <div class="col-6">
                                    <div class="pb-hero-sub position-relative overflow-hidden">
                                        <a href="/news/@n.Slug">
                                            <img src="@(n.FeaturedImage ?? "/images/placeholder.jpg")"
                                                 alt="@n.Title"
                                                 class="pb-hero-sub-img"
                                                 loading="lazy"
                                                 onerror="this.src='/images/placeholder.jpg'" />
                                        </a>
                                        <div class="pb-hero-sub-overlay">
                                            @if (n.IsBreaking)
                                            {
                                                <span class="pb-breaking-tag">ব্রেকিং</span>
                                            }
                                            <h6 class="pb-hero-sub-title">
                                                <a href="/news/@n.Slug"
                                                   class="text-white text-decoration-none">
                                                    @n.Title
                                                </a>
                                            </h6>

                                        </div>

                                    </div>

                                </div>
                            }
                        </div>

                    </div>

                </div>

            </section>
        }

        <!-- ══ LATEST NEWS ROW ══════════════════════════════ -->
        @if (Model.LatestNews.Any())
        {
            <section class="mt-4">

                <div class="pb-section-hdr">

                    <h2 class="pb-sec-title">সর্বশেষ সংবাদ</h2>

                    <a href="/news" class="pb-sec-more">আরও →</a>
                </div>

                <div class="row g-2 mt-2">
                    @foreach (var n in Model.LatestNews.Take(6))
                    {
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="pb-mini-card">
                                <a href="/news/@n.Slug" class="pb-mini-img-link">
                                    <img src="@(n.FeaturedImage ?? "/images/placeholder.jpg")"
                                         alt="@n.Title"
                                         class="pb-mini-img"
                                         loading="lazy"
                                         onerror="this.src='/images/placeholder.jpg'" />
                                </a>

                                <h6 class="pb-mini-title">
                                    <a href="/news/@n.Slug"
                                       class="text-dark text-decoration-none">
                                        @n.Title
                                    </a>

                                </h6>

                                <div class="pb-mini-meta">
                                    <i class="bi bi-clock me-1"></i>
                                    @n.PublishedAt?.ToString("dd MMM")
                                </div>

                            </div>

                        </div>
                    }
                </div>

            </section>
        }

        <!-- ══ REGIONAL NEWS FILTER ═══════════════════════════ -->
        <section class="pb-region-filter mt-4">
            <form action="/news" method="get" class="pb-region-filter-inner">
                <span class="pb-region-label">সব বিভাগের খবর</span>

                <select name="division" id="filter-division" class="form-select pb-region-select">
                    <option value="">বিভাগ</option>
                    @foreach (var div in NewsPortalPro.Data.BangladeshLocations.GetDivisions())
                    {
                        <option value="@div">@div</option>
                    }
                </select>

                <select name="district" id="filter-district" class="form-select pb-region-select">
                    <option value="">জেলা</option>
                </select>

                <button type="submit" class="pb-region-search-btn">
                    অনুসন্ধান করুন <i class="bi bi-search ms-1"></i>
                </button>
            </form>
        </section>

        <!-- ══ ARCHIVE (তারিখ অনুসারে) ═══════════════════════ -->
        <section class="pb-archive-section mt-3">
            <form action="/news" method="get" class="pb-archive-inner">
                <span class="pb-archive-label"><i class="bi bi-calendar3 me-1"></i>আর্কাইভ</span>

                <select name="archiveYear" id="archive-year" class="form-select pb-archive-select">
                    <option value="">বছর</option>
                    @{
                        var currentYear = DateTime.Now.Year;
                    }
                    @for (int y = currentYear; y >= currentYear - 10; y--)
                    {
                        <option value="@y">@y</option>
                    }
                </select>

                <select name="archiveMonth" id="archive-month" class="form-select pb-archive-select">
                    <option value="">মাস</option>
                    <option value="1">জানুয়ারি</option>
                    <option value="2">ফেব্রুয়ারি</option>
                    <option value="3">মার্চ</option>
                    <option value="4">এপ্রিল</option>
                    <option value="5">মে</option>
                    <option value="6">জুন</option>
                    <option value="7">জুলাই</option>
                    <option value="8">আগস্ট</option>
                    <option value="9">সেপ্টেম্বর</option>
                    <option value="10">অক্টোবর</option>
                    <option value="11">নভেম্বর</option>
                    <option value="12">ডিসেম্বর</option>
                </select>

                <select name="archiveDay" id="archive-day" class="form-select pb-archive-select">
                    <option value="">দিন</option>
                    @for (int d = 1; d <= 31; d++)
                    {
                        <option value="@d">@d</option>
                    }
                </select>

                <button type="submit" class="pb-archive-search-btn">
                    দেখুন <i class="bi bi-search ms-1"></i>
                </button>
            </form>
        </section>


        <!-- ══ VIDEO SECTION ══════════════════════════════════ -->
        @if (Model.Videos.Any())
        {
            <section class="pb-video-section mt-4">
                <div class="pb-section-hdr">
                    <h2 class="pb-sec-title">ভিডিও</h2>
                    <a href="/videos" class="pb-sec-more">আরও ভিডিও →</a>
                </div>

                @{
                    var topVideos = Model.Videos.Take(2).ToList();
                    var restVideos = Model.Videos.Skip(2).ToList();
                }

                @if (topVideos.Any())
                {
                    <div class="pb-video-top-row mt-2">
                        @foreach (var v in topVideos)
                        {
                            <a href="@v.VideoUrl" target="_blank" class="pb-video-card-lg">
                                <img src="@(v.ThumbnailUrl ?? "/images/placeholder.jpg")"
                                     alt="@v.Title"
                                     onerror="this.src='/images/placeholder.jpg'" />
                                <span class="pb-video-play-icon">
                                    <i class="bi bi-play-fill"></i>
                                </span>
                                <span class="pb-video-title-band">@v.Title</span>
                            </a>
                        }
                    </div>
                }

                @if (restVideos.Any())
                {
                    <div class="pb-video-scroll-wrap mt-2">
                        <button class="pb-video-scroll-btn pb-video-scroll-prev" aria-label="আগের ভিডিও">
                            <i class="bi bi-chevron-left"></i>
                        </button>

                        <div class="pb-video-scroll-track">
                            @foreach (var v in restVideos)
                            {
                                <a href="@v.VideoUrl" target="_blank" class="pb-video-card-sm">
                                    <img src="@(v.ThumbnailUrl ?? "/images/placeholder.jpg")"
                                         alt="@v.Title"
                                         onerror="this.src='/images/placeholder.jpg'" />
                                    <span class="pb-video-play-icon pb-video-play-icon-sm">
                                        <i class="bi bi-play-fill"></i>
                                    </span>
                                    <span class="pb-video-title-band pb-video-title-band-sm">@v.Title</span>
                                </a>
                            }
                        </div>

                        <button class="pb-video-scroll-btn pb-video-scroll-next" aria-label="পরবর্তী ভিডিও">
                            <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                }
            </section>
        }

        <!-- ══ MAIN CONTENT + SIDEBAR ═══════════════════════ -->


        <div class="row g-4 mt-1">


            <!-- Left: Category blocks -->


            <div class="col-lg-9">

                @{
                    var blockList = Model.CategoryNewsBlocks.ToList();
                    var insertAfter = 3; // insert quick-links after 3rd category block
                    var blockIndex = 0;
                }
                @foreach (var block in blockList)
                {
                    var cat = block.Value.Category;
                    var catNews = block.Value.News;
                    if (!catNews.Any()) continue;
                    var count = catNews.Count;
                    blockIndex++;

                    <section class="pb-cat-block mb-4" id="cat-@cat.Slug">
                        <div class="pb-section-hdr">
                            <h2 class="pb-sec-title"
                                style="border-left:4px solid @(cat.ColorCode ?? "#c0392b");
                                padding-left:8px">
                                <a href="/category/@cat.Slug"
                                   class="text-dark text-decoration-none">
                                    @cat.Name
                                </a>

                            </h2>

                            <a href="/category/@cat.Slug"
                               class="pb-sec-more"
                               style="color:@(cat.ColorCode ?? "#c0392b")">
                                আরও →

                            </a>

                        </div>

                        @if (count >= 5)
                        {
                            <div class="row g-2 mt-1">

                                <div class="col-md-5">

                                    <div class="pb-lead2">

                                        <a href="/news/@catNews[0].Slug"
                                           class="pb-lead2-img-link">
                                            <img src="@(catNews[0].FeaturedImage ?? "/images/placeholder.jpg")"
                                                 alt="@catNews[0].Title"
                                                 class="pb-lead2-img"
                                                 loading="lazy"
                                                 onerror="this.src='/images/placeholder.jpg'" />
                                        </a>

                                        <h3 class="pb-lead2-title mt-2">
                                            <a href="/news/@catNews[0].Slug"
                                               class="text-dark text-decoration-none">
                                                @catNews[0].Title
                                            </a>
                                        </h3>

                                        <p class="pb-lead2-summary">
                                            @catNews[0].Summary
                                        </p>

                                        <div class="pb-meta-sm">
                                            <i class="bi bi-clock me-1"></i>
                                            @catNews[0].PublishedAt?.ToString("dd MMM yyyy")
                                        </div>

                                    </div>

                                </div>

                                <div class="col-md-7">
                                    <div class="row g-2">
                                        @foreach (var n in catNews.Skip(1).Take(4))
                                        {
                                            <div class="col-6 col-md-4 col-lg-3">
                                                <div class="pb-grid-card">
                                                    <a href="/news/@n.Slug"
                                                       class="pb-grid-img-link">
                                                        <img src="@(n.FeaturedImage ?? "/images/placeholder.jpg")"
                                                             alt="@n.Title"
                                                             class="pb-grid-img"
                                                             loading="lazy"
                                                             onerror="this.src='/images/placeholder.jpg'" />
                                                    </a>

                                                    <h6 class="pb-grid-title">
                                                        <a href="/news/@n.Slug"
                                                           class="text-dark text-decoration-none">
                                                            @n.Title
                                                        </a>

                                                    </h6>

                                                    <div class="pb-meta-sm">
                                                        @n.PublishedAt?.ToString("dd MMM")
                                                    </div>

                                                </div>

                                            </div>
                                        }

                                    </div>

                                </div>

                            </div>
                        }

                        else if (count >= 3)

                        {
                            <div class="row g-2 mt-1">
                                @foreach (var n in catNews.Take(4))
                                {
                                    <div class="col-6 col-md-3">
                                        <div class="pb-grid-card">
                                            <a href="/news/@n.Slug"
                                               class="pb-grid-img-link">
                                                <img src="@(n.FeaturedImage ?? "/images/placeholder.jpg")"
                                                     alt="@n.Title"
                                                     class="pb-grid-img"
                                                     loading="lazy"
                                                     onerror="this.src='/images/placeholder.jpg'" />
                                            </a>

                                            <h6 class="pb-grid-title">
                                                <a href="/news/@n.Slug"
                                                   class="text-dark text-decoration-none">
                                                    @n.Title
                                                </a>

                                            </h6>
                                            <p class="pb-grid-summary">@n.Summary</p>
                                            <div class="pb-meta-sm">
                                                <i class="bi bi-clock me-1"></i>
                                                @n.PublishedAt?.ToString("dd MMM")
                                            </div>

                                        </div>

                                    </div>
                                }

                            </div>
                        }
                        else
                        {
                            <div class="row g-2 mt-1">
                                @foreach (var n in catNews.Take(2))
                                {
                                    <div class="col-6 col-md-4 col-lg-3">
                                        <div class="pb-grid-card">
                                            <a href="/news/@n.Slug"
                                               class="pb-grid-img-link">
                                                <img src="@(n.FeaturedImage ?? "/images/placeholder.jpg")"
                                                     alt="@n.Title"
                                                     class="pb-grid-img"
                                                     loading="lazy"
                                                     onerror="this.src='/images/placeholder.jpg'" />
                                            </a>

                                            <h6 class="pb-grid-title">
                                                <a href="/news/@n.Slug"
                                                   class="text-dark text-decoration-none">
                                                    @n.Title
                                                </a>

                                            </h6>

                                            <div class="pb-meta-sm">
                                                <i class="bi bi-clock me-1"></i>
                                                @n.PublishedAt?.ToString("dd MMM")
                                            </div>

                                        </div>

                                    </div>
                                }
                            </div>
                        }

                        <hr class="pb-divider" />

                    </section>

                    @* ── Insert quick-links section after Nth block ── *@
                    @if (blockIndex == insertAfter)
                    {
                        <section class="pb-quicklinks-section mb-4">
                            <div class="pb-quicklinks-inner">
                                <span class="pb-quicklinks-label">আরও দেখুন</span>
                                <div class="pb-quicklinks-grid">
                                    @foreach (var ql in blockList
                                        .Skip(insertAfter)
                                        .Select(b => b.Value.Category)
                                        .Take(8))
                                    {
                                        <a href="/category/@ql.Slug"
                                           class="pb-quicklink-item">
                                            <i class="bi bi-grid-3x3-gap-fill me-1"
                                               style="font-size:.7rem"></i>
                                            @ql.Name
                                        </a>
                                    }
                                </div>
                            </div>
                        </section>
                    }
                }

            </div>


            <!-- Right: Sidebar -->

            <div class="col-lg-3">

                <div class="pb-sidebar">

                    <div class="pb-widget mb-4">

                        <div class="pb-section-hdr mb-3">

                            <h2 class="pb-sec-title">

                                <i class="bi bi-fire text-danger me-1"></i>

                                সর্বাধিক পঠিত

                            </h2>

                        </div>
                        @foreach (var (n, i) in Model.TrendingNews
                            .Select((x, idx) => (x, idx + 1)).Take(8))
                        {
                            <div class="pb-trending-item">
                                <span class="pb-trending-num">@i</span>
                                <div class="flex-grow-1">
                                    <a href="/news/@n.Slug"
                                       class="pb-trending-title
                                        text-dark text-decoration-none">
                                        @n.Title
                                    </a>

                                    <div class="pb-meta-sm mt-1">
                                        <i class="bi bi-clock me-1"></i>
                                        @n.PublishedAt?.ToString("dd MMM")
                                    </div>

                                </div>

                            </div>
                        }

                    </div>

                    @foreach (var ad in Model.SidebarAds.Take(3))
                    {
                        <div class="pb-widget mb-3 text-center p-0 overflow-hidden">
                            @if (!string.IsNullOrEmpty(ad.HtmlCode))
                            {
                                @Html.Raw(ad.HtmlCode)
                            }
                            else if (!string.IsNullOrEmpty(ad.ImageUrl))
                            {
                                <a href="@ad.TargetUrl" target="_blank"
                                   onclick="trackAdClick(@ad.Id)">
                                    <img src="@ad.ImageUrl" alt="@ad.Title"
                                         class="img-fluid w-100" />
                                </a>
                            }

                        </div>
                    }


                    <div class="pb-widget mb-4">
                        <div class="pb-section-hdr mb-3">
                            <h2 class="pb-sec-title">নিউজলেটার</h2>
                        </div>

                        <p class="small text-muted mb-2">
                            সর্বশেষ সংবাদ সরাসরি ইনবক্সে পান
                        </p>

                        <div class="input-group input-group-sm">
                            <input type="email" id="newsletter-email"
                                   class="form-control"
                                   placeholder="আপনার ইমেইল" />
                            <button class="btn btn-danger btn-sm"
                                    onclick="subscribeNewsletter()">
                                সাবস্ক্রাইব

                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div><!-- /pb-page-container -->

</div><!-- /pb-home-wrapper -->
@section Scripts {

    <script>
        async function subscribeNewsletter() {
            const email = document.getElementById('newsletter-email')
                ?.value?.trim();
            if (!email) { toastr.warning('ইমেইল লিখুন'); return; }
            try {
                const res = await fetch('/api/newsletter/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                if (res.ok) toastr.success('সাবস্ক্রাইব সফল হয়েছে!');
                else        toastr.error('সাবস্ক্রাইব ব্যর্থ হয়েছে');
            } catch { toastr.error('নেটওয়ার্ক ত্রুটি'); }
        }

            document.getElementById('filter-division')?.addEventListener('change', async function () {
            var districtSelect = document.getElementById('filter-district');
            districtSelect.innerHTML = '<option value="">জেলা</option>';
            if (!this.value) return;

            try {
                var res = await fetch('/api/locations/districts?division=' + encodeURIComponent(this.value));
                var districts = await res.json();
                districts.forEach(function (d) {
                    var opt = document.createElement('option');
                    opt.value = d;
                    opt.textContent = d;
                    districtSelect.appendChild(opt);
                });
            } catch (e) { }
        });

                function updateArchiveDays() {
            var yearSel = document.getElementById('archive-year');
            var monthSel = document.getElementById('archive-month');
            var daySel = document.getElementById('archive-day');
            if (!yearSel || !monthSel || !daySel) return;

            var year = parseInt(yearSel.value) || new Date().getFullYear();
            var month = parseInt(monthSel.value) || 1;
            var daysInMonth = new Date(year, month, 0).getDate();

            var currentDay = daySel.value;
            daySel.innerHTML = '<option value="">দিন</option>';
            for (var d = 1; d <= daysInMonth; d++) {
                var opt = document.createElement('option');
                opt.value = d;
                opt.textContent = d;
                daySel.appendChild(opt);
            }
            if (currentDay && parseInt(currentDay) <= daysInMonth) {
                daySel.value = currentDay;
            }
        }

        document.getElementById('archive-year')?.addEventListener('change', updateArchiveDays);
        document.getElementById('archive-month')?.addEventListener('change', updateArchiveDays);
    </script>

}