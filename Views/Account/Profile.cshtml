@using NewsPortalPro.Models
@model ApplicationUser
@{
    ViewData["Title"] = "আমার প্রোফাইল";
}

<div class="container mt-4" style="max-width:800px">
    <div class="row g-4">

        <!-- Profile Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4">
                @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                {
                    <img src="@Model.ProfilePicture"
                         alt="@Model.FullName"
                         class="rounded-circle mx-auto mb-3"
                         width="100" height="100"
                         style="object-fit:cover" />
                }
                else
                {
                    <div class="rounded-circle mx-auto mb-3 d-flex
                                    align-items-center justify-content-center fw-bold fs-2"
                         style="width:100px;height:100px;
                                    background:var(--primary);color:white">
                        @Model.FullName[0]
                    </div>
                }
                <h5 class="fw-bold mb-1">@Model.FullName</h5>
                <p class="text-muted small mb-1">@Model.Designation</p>
                <p class="text-muted small">@Model.Email</p>
                <p class="text-muted small">
                    যোগদান: @Model.CreatedAt.ToString("dd MMM yyyy")
                </p>
            </div>
        </div>

        <!-- Edit Form -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }

                    <ul class="nav nav-tabs mb-4" id="profileTabs">
                        <li class="nav-item">
                            <button class="nav-link active"
                                    data-bs-toggle="tab"
                                    data-bs-target="#info-tab">
                                প্রোফাইল তথ্য
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#password-tab">
                                পাসওয়ার্ড পরিবর্তন
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">

                        <!-- Profile Info Tab -->
                        <div class="tab-pane fade show active" id="info-tab">
                            <form asp-action="UpdateProfile"
                                  asp-controller="Account"
                                  method="post">
                                @Html.AntiForgeryToken()
                                <div class="mb-3">
                                    <label class="form-label fw-medium">পূর্ণ নাম</label>
                                    <input type="text" name="FullName"
                                           value="@Model.FullName"
                                           class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium">পদবী</label>
                                    <input type="text" name="Designation"
                                           value="@Model.Designation"
                                           class="form-control"
                                           placeholder="যেমন: সিনিয়র রিপোর্টার" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium">বায়ো</label>
                                    <textarea name="Bio" class="form-control"
                                              rows="3"
                                              placeholder="আপনার সম্পর্কে লিখুন...">@Model.Bio</textarea>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium">Facebook URL</label>
                                    <input type="url" name="FacebookUrl"
                                           value="@Model.FacebookUrl"
                                           class="form-control"
                                           placeholder="https://facebook.com/..." />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium">Twitter URL</label>
                                    <input type="url" name="TwitterUrl"
                                           value="@Model.TwitterUrl"
                                           class="form-control"
                                           placeholder="https://twitter.com/..." />
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save me-2"></i>সংরক্ষণ করুন
                                </button>
                            </form>
                        </div>

                        <!-- Password Tab -->
                        <div class="tab-pane fade" id="password-tab">
                            <form asp-action="ChangePassword"
                                  asp-controller="Account"
                                  method="post">
                                @Html.AntiForgeryToken()
                                <div class="mb-3">
                                    <label class="form-label fw-medium">
                                        বর্তমান পাসওয়ার্ড
                                    </label>
                                    <input type="password"
                                           name="CurrentPassword"
                                           class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium">
                                        নতুন পাসওয়ার্ড
                                    </label>
                                    <input type="password"
                                           name="NewPassword"
                                           class="form-control"
                                           minlength="8" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-medium">
                                        নতুন পাসওয়ার্ড নিশ্চিত করুন
                                    </label>
                                    <input type="password"
                                           name="ConfirmPassword"
                                           class="form-control"
                                           minlength="8" required />
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-key me-2"></i>পাসওয়ার্ড পরিবর্তন করুন
                                </button>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>