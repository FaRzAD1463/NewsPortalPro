@using NewsPortalPro.Models
@model Epaper
@{
    ViewData["Title"] = "ই-পেপার";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (ViewBag.NoPaper == true)
{
    <div class="text-center py-5">
        <i class="bi bi-newspaper fs-1 text-muted"></i>
        <h4 class="mt-3 text-muted">কোনো ই-পেপার পাওয়া যায়নি</h4>
        <p class="text-muted">অ্যাডমিন ই-পেপার আপলোড করেননি।</p>
        <a href="/" class="btn btn-primary">হোমে ফিরুন</a>
    </div>
}
else
{
    <!-- E-paper toolbar -->
    <div class="epaper-toolbar">
        <div class="pb-page-container d-flex align-items-center
                    justify-content-between flex-wrap gap-2 py-2">
            <div class="d-flex align-items-center gap-3">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-newspaper me-2 text-danger"></i>
                    ই-পেপার
                </h5>
                <span class="text-muted small">
                    @Model.Title —
                    @Model.PublishedDate.ToString("dd MMMM yyyy")
                </span>
            </div>
            <div class="d-flex gap-2">
                <a href="@Model.PdfUrl" download
                   class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-download me-1"></i>ডাউনলোড
                </a>
                <a href="/Epaper/Archive"
                   class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-archive me-1"></i>পুরনো সংখ্যা
                </a>
                <button onclick="toggleFullscreen()"
                        class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-fullscreen" id="fullscreen-icon"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Main e-paper layout -->
    <div class="epaper-layout" id="epaper-layout">

        <!-- PDF viewer panel -->
        <div class="epaper-pdf-panel" id="pdf-panel">
            <div class="pdf-controls">
                <button onclick="prevPage()"
                        class="btn btn-sm btn-light" id="prev-btn"
                        disabled>
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="pdf-page-info small">
                    পৃষ্ঠা <span id="page-num">1</span> /
                    <span id="page-count">—</span>
                </span>
                <button onclick="nextPage()"
                        class="btn btn-sm btn-light" id="next-btn">
                    <i class="bi bi-chevron-right"></i>
                </button>
                <button onclick="zoomIn()"
                        class="btn btn-sm btn-light ms-2">
                    <i class="bi bi-zoom-in"></i>
                </button>
                <button onclick="zoomOut()"
                        class="btn btn-sm btn-light">
                    <i class="bi bi-zoom-out"></i>
                </button>
            </div>
            <div class="pdf-canvas-wrapper" id="canvas-wrapper">
                <canvas id="pdf-canvas"></canvas>
                <div id="pdf-loading" class="pdf-loading">
                    <div class="spinner-border text-danger"></div>
                    <p class="mt-2 text-muted small">লোড হচ্ছে...</p>
                </div>
            </div>
        </div>

        <!-- Article panel — shows when article clicked -->
        <div class="epaper-article-panel" id="article-panel">
            <div class="article-panel-header">
                <span class="fw-bold small">নির্বাচিত সংবাদ</span>
                <button onclick="closeArticle()"
                        class="btn btn-sm btn-link text-muted p-0">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="article-panel-body" id="article-body">
                <div class="text-center text-muted py-5">
                    <i class="bi bi-hand-index fs-2"></i>
                    <p class="mt-2 small">
                        নিচের তালিকা থেকে সংবাদ নির্বাচন করুন
                    </p>
                </div>
            </div>
        </div>

        <!-- News list panel -->
        <div class="epaper-news-panel" id="news-panel">
            <div class="news-panel-header">
                <h6 class="mb-0 fw-bold">সংবাদ তালিকা</h6>
                <input type="text" id="news-search"
                       class="form-control form-control-sm mt-2"
                       placeholder="সংবাদ খুঁজুন..."
                       oninput="filterNews(this.value)" />
            </div>
            <div class="news-panel-list" id="news-list">
                <!-- Populated by JS -->
            </div>
        </div>

    </div>
}

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs"
        type="module"></script>
<script type="module">
    import * as pdfjsLib from
        'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs';

    pdfjsLib.GlobalWorkerOptions.workerSrc =
        'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs';

    const pdfUrl   = '@(Model?.PdfUrl ?? "")';
    const newsData = @Html.Raw(ViewBag.NewsJson ?? "[]");

    let pdfDoc    = null;
    let pageNum   = 1;
    let pageScale = 1.4;
    let rendering = false;

    const canvas  = document.getElementById('pdf-canvas');
    const ctx     = canvas ? canvas.getContext('2d') : null;
    const loading = document.getElementById('pdf-loading');

    // ── Load PDF ───────────────────────────────────────────────
    if (pdfUrl) {
        pdfjsLib.getDocument(pdfUrl).promise.then(function(pdf) {
            pdfDoc = pdf;
            document.getElementById('page-count').textContent =
                pdf.numPages;
            if (loading) loading.style.display = 'none';
            renderPage(1);
        }).catch(function(err) {
            if (loading) loading.innerHTML =
                '<p class="text-danger small">PDF লোড হয়নি।</p>';
            console.error('PDF load error:', err);
        });
    }

    function renderPage(num) {
        if (!pdfDoc || rendering) return;
        rendering = true;

        pdfDoc.getPage(num).then(function(page) {
            var viewport = page.getViewport({ scale: pageScale });
            canvas.height = viewport.height;
            canvas.width  = viewport.width;

            page.render({ canvasContext: ctx, viewport: viewport })
                .promise.then(function() {
                    rendering = false;
                    document.getElementById('page-num').textContent = num;
                    document.getElementById('prev-btn').disabled = num <= 1;
                    document.getElementById('next-btn').disabled =
                        num >= pdfDoc.numPages;
                });
        });
    }

    window.prevPage = function() {
        if (pageNum <= 1) return;
        renderPage(--pageNum);
    };
    window.nextPage = function() {
        if (!pdfDoc || pageNum >= pdfDoc.numPages) return;
        renderPage(++pageNum);
    };
    window.zoomIn = function() {
        pageScale = Math.min(pageScale + 0.2, 3.0);
        renderPage(pageNum);
    };
    window.zoomOut = function() {
        pageScale = Math.max(pageScale - 0.2, 0.5);
        renderPage(pageNum);
    };

    // ── Populate news list ─────────────────────────────────────
    var list = document.getElementById('news-list');

    function buildNewsItem(n) {
        var img   = n.featuredImage || '/images/placeholder.jpg';
        var cat   = n.categoryName  || '';
        var color = n.categoryColor || '#c0392b';
        var date  = n.publishedAt
            ? new Date(n.publishedAt).toLocaleDateString('bn-BD')
            : '';

        var div = document.createElement('div');
        div.className = 'epaper-news-item';
        div.setAttribute('data-id', n.id);
        div.setAttribute('data-title', (n.title || '').toLowerCase());
        div.onclick = function() { showArticle(n.id); };

        div.innerHTML =
            '<div class="d-flex gap-2">' +
                '<img src="' + img + '" ' +
                     'onerror="this.src=\'/images/placeholder.jpg\'" ' +
                     'class="epaper-news-thumb" />' +
                '<div class="flex-grow-1 min-width-0">' +
                    '<div class="epaper-cat-label" ' +
                         'style="color:' + color + '">' +
                        cat +
                    '</div>' +
                    '<div class="epaper-news-title">' +
                        (n.title || '') +
                    '</div>' +
                    '<div class="epaper-news-meta">' + date + '</div>' +
                '</div>' +
            '</div>';

        return div;
    }

    function renderNewsList(items) {
        if (!list) return;
        list.innerHTML = '';
        items.forEach(function(n) {
            list.appendChild(buildNewsItem(n));
        });
    }

    renderNewsList(newsData);

    window.filterNews = function(query) {
        var q = query.toLowerCase().trim();
        var filtered = q
            ? newsData.filter(function(n) {
                return n.title.toLowerCase().indexOf(q) !== -1;
              })
            : newsData;
        renderNewsList(filtered);
    };

    // ── Show article ───────────────────────────────────────────
    window.showArticle = async function(id) {
        var body  = document.getElementById('article-body');
        var panel = document.getElementById('article-panel');

        body.innerHTML =
            '<div class="text-center py-4">' +
                '<div class="spinner-border spinner-border-sm ' +
                'text-danger"></div>' +
            '</div>';
        panel.classList.add('active');

        document.querySelectorAll('.epaper-news-item')
            .forEach(function(el) { el.classList.remove('active'); });
        var active = document.querySelector(
            '.epaper-news-item[data-id="' + id + '"]');
        if (active) active.classList.add('active');

        try {
            var res  = await fetch('/api/news/' + id + '/detail');
            var news = await res.json();

            var catHtml = news.categoryName
                ? '<a href="/category/' + news.categorySlug + '" ' +
                  'class="small fw-bold text-danger text-decoration-none">' +
                  news.categoryName + '</a>'
                : '';

            var imgHtml = news.featuredImage
                ? '<img src="' + news.featuredImage + '" ' +
                  'class="img-fluid rounded mb-3 w-100" ' +
                  'style="max-height:250px;object-fit:cover" />'
                : '';

            body.innerHTML =
                '<div class="p-3">' +
                    catHtml +
                    '<h4 class="fw-bold mt-1 mb-2">' +
                        (news.title || '') +
                    '</h4>' +
                    imgHtml +
                    '<p class="text-muted small mb-3">' +
                        (news.summary || '') +
                    '</p>' +
                    '<div class="article-content small" ' +
                         'style="line-height:1.8">' +
                        (news.content || '') +
                    '</div>' +
                    '<div class="mt-3 pt-3 border-top">' +
                        '<a href="/news/' + news.slug + '" ' +
                           'target="_blank" ' +
                           'class="btn btn-danger btn-sm w-100">' +
                            '<i class="bi bi-box-arrow-up-right me-1"></i>' +
                            'সম্পূর্ণ সংবাদ পড়ুন' +
                        '</a>' +
                    '</div>' +
                '</div>';
        } catch(e) {
            body.innerHTML =
                '<p class="text-danger p-3 small">সংবাদ লোড হয়নি।</p>';
        }
    };

    window.closeArticle = function() {
        document.getElementById('article-panel')
            .classList.remove('active');
        document.querySelectorAll('.epaper-news-item')
            .forEach(function(el) { el.classList.remove('active'); });
    };

    window.toggleFullscreen = function() {
        var layout = document.getElementById('epaper-layout');
        if (!document.fullscreenElement) {
            layout.requestFullscreen();
            document.getElementById('fullscreen-icon').className =
                'bi bi-fullscreen-exit';
        } else {
            document.exitFullscreen();
            document.getElementById('fullscreen-icon').className =
                'bi bi-fullscreen';
        }
    };
</script>
}