@model NewsPortalPro.DTOs.NewsListDto

<div class="pb-news-card">
    <a href="/news/@Model.Slug" class="pb-card-img-link">
        <div class="pb-card-img-wrapper">
            <img src="@(Model.FeaturedImage ?? "/images/placeholder.jpg")"
                 alt="@(Model.FeaturedImageAlt ?? Model.Title)"
                 class="pb-card-img"
                 loading="lazy"
                 onerror="this.src='/images/placeholder.jpg'" />
            @if (Model.IsBreaking)
            {
                <span class="pb-breaking-tag">ব্রেকিং</span>
            }
            @if (Model.Type == NewsPortalPro.Models.NewsType.Video)
            {
                <span class="pb-video-tag">
                    <i class="bi bi-play-circle-fill"></i>
                </span>
            }
        </div>
    </a>
    <div class="pb-card-body">
        @if (!string.IsNullOrEmpty(Model.CategoryName))
        {
            <a href="/category/@Model.CategorySlug"
               class="pb-card-category"
               style="color:@(Model.CategoryColor ?? "#c0392b")">
                @Model.CategoryName
            </a>
        }
        <h3 class="pb-card-title">
            <a href="/news/@Model.Slug">@Model.Title</a>
        </h3>
        @if (!string.IsNullOrEmpty(Model.Summary))
        {
            <p class="pb-card-summary">@Model.Summary</p>
        }
        <div class="pb-card-meta">
            @if (Model.PublishedAt.HasValue)
            {
                <span class="pb-card-time">
                    <i class="bi bi-clock me-1"></i>
                    @GetTimeAgo(Model.PublishedAt.Value)
                </span>
            }
            <span class="pb-card-views">
                <i class="bi bi-eye me-1"></i>@Model.ViewCount
            </span>
        </div>
    </div>
</div>

@functions {
    string GetTimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 60)
            return $"{(int)diff.TotalMinutes} মিনিট আগে";
        if (diff.TotalHours < 24)
            return $"{(int)diff.TotalHours} ঘন্টা আগে";
        if (diff.TotalDays < 7)
            return $"{(int)diff.TotalDays} দিন আগে";
        return dt.ToString("dd MMM yyyy");
    }
}