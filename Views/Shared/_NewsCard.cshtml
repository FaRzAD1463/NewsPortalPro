@model NewsPortalPro.DTOs.NewsListDto

<div class="news-card card h-100 border-0 shadow-sm">
    <div class="card-img-wrapper position-relative overflow-hidden">
        <a href="/news/@Model.Slug">
            <img src="@(Model.FeaturedImage ?? "/images/placeholder.jpg")"
                 alt="@(Model.FeaturedImageAlt ?? Model.Title)"
                 class="card-img-top"
                 loading="lazy"
                 onerror="this.src='/images/placeholder.jpg'" />
        </a>
        @if (Model.IsBreaking)
        {
            <span class="position-absolute top-0 start-0 badge bg-danger m-2">ব্রেকিং</span>
        }
        @if (Model.Type == NewsType.Video)
        {
            <span class="position-absolute bottom-0 end-0 badge bg-dark m-2">
                <i class="bi bi-play-circle-fill me-1"></i>ভিডিও
            </span>
        }
    </div>
    <div class="card-body p-3">
        <span class="category-badge small mb-1" style="background:@(Model.CategoryColor ?? "#6c757d")">
            @Model.CategoryName
        </span>
        <h6 class="card-title mt-1 mb-2 news-title-clamp">
            <a href="/news/@Model.Slug" class="text-dark text-decoration-none">@Model.Title</a>
        </h6>
        <div class="card-meta d-flex justify-content-between align-items-center">
            <small class="text-muted">
                <i class="bi bi-clock me-1"></i>
                @(Model.PublishedAt.HasValue? Model.PublishedAt.Value.ToString("dd MMM") : "")
            </small>
            <div class="d-flex gap-2">
                <small class="text-muted"><i class="bi bi-eye me-1"></i>@Model.ViewCount</small>
                <small class="text-muted"><i class="bi bi-chat me-1"></i>@Model.CommentCount</small>
            </div>
        </div>
    </div>
</div>