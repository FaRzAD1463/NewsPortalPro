@using NewsPortalPro.Interfaces
@using NewsPortalPro.DTOs
@inject ICategoryService CategoryService

@{
    var categories = await CategoryService.GetMenuCategoriesAsync();
}

@foreach (var cat in categories)
{
    <li class="nav-item-custom dropdown-hover">
        <a class="nav-link-custom" href="/category/@cat.Slug">
            @cat.Name
            @if (cat.Children != null && cat.Children.Any())
            {
                <i class="bi bi-chevron-down ms-1" style="font-size:10px"></i>
            }
        </a>
        <div class="mega-dropdown">
            <div class="mega-dropdown-inner">
                <div class="row g-0">
                    <!-- Sub categories -->
                    @if (cat.Children != null && cat.Children.Any())
                    {
                        <div class="col-3 mega-sub-cats border-end">
                            <div class="p-3">
                                <h6 class="fw-bold mb-3"
                                    style="color:@cat.ColorCode;border-bottom:2px solid @cat.ColorCode;padding-bottom:8px">
                                    @cat.Name
                                </h6>
                                @foreach (var child in cat.Children)
                                {
                                    <a href="/category/@child.Slug"
                                       class="d-flex align-items-center gap-2 py-2 text-decoration-none sub-cat-link">
                                        <i class="bi bi-chevron-right small"></i>
                                        <span>@child.Name</span>
                                    </a>
                                }
                            </div>
                        </div>
                        <div class="col-9 p-3" id="mega-news-@cat.Slug">
                            <div class="text-center text-muted py-3">
                                <div class="spinner-border spinner-border-sm"></div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="col-12 p-3" id="mega-news-@cat.Slug">
                            <div class="text-center text-muted py-3">
                                <div class="spinner-border spinner-border-sm"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </li>
}