<!DOCTYPE html>
<html lang="bn" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? ViewBag.SiteDescription ?? "বাংলাদেশের নির্ভরযোগ্য সংবাদ মাধ্যম")" />
    <meta name="keywords" content="@ViewData["Keywords"]" />

    <!-- Open Graph -->
    <meta property="og:title" content="@ViewData["Title"] - @(ViewBag.SiteName ?? "নিউজপোর্টাল প্রো")" />
    <meta property="og:description" content="@ViewData["Description"]" />
    <meta property="og:image" content="@ViewData["OgImage"]" />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="bn_BD" />

    <title>@ViewData["Title"] - @(ViewBag.SiteName ?? "নিউজপোর্টাল প্রো")</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Bengali:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap + Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Toastr + AOS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ══ SITE HEADER ══════════════════════════════════ -->
    <header id="main-header" class="pb-site-header">
        <div class="pb-header-inner">

            <!-- Left: hamburger + date -->
            <div class="pb-header-left">
                <button class="pb-hamburger d-lg-none"
                        data-bs-toggle="offcanvas"
                        data-bs-target="#mobileMenu">
                    <i class="bi bi-list"></i>
                </button>
                <div class="pb-header-date" id="current-date-header"></div>
            </div>

            <!-- Center: Logo -->
            <div class="pb-header-logo">
                <a href="/" class="text-decoration-none">
                    @if (!string.IsNullOrEmpty(ViewBag.LogoUrl as string)
                         && ViewBag.LogoUrl != "/images/logo.png")
                    {
                        <img src="@ViewBag.LogoUrl"
                             alt="@(ViewBag.SiteName ?? "নিউজপোর্টাল প্রো")"
                             class="pb-logo-img" />
                    }
                    else
                    {
                        <div class="pb-logo-text">
                            নিউজপোর্টাল প্রো
                        </div>
                    }
                </a>
                @if (!string.IsNullOrEmpty(ViewBag.SiteTagline as string))
                {
                    <div class="pb-logo-tagline">@ViewBag.SiteTagline</div>
                }
            </div>

            <!-- Right: E-Paper + Theme + Auth -->
            <div class="pb-header-right">
                <a href="/Epaper"
                   class="pb-epaper-btn d-none d-md-inline-flex">
                    ই-পেপার
                </a>
                <button id="theme-toggle" class="pb-icon-btn"
                        title="থিম পরিবর্তন">
                    <i class="bi bi-moon-fill"></i>
                </button>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="dropdown">
                        <button class="pb-user-btn dropdown-toggle"
                                data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>
                            <span class="d-none d-md-inline">
                                @User.Identity.Name
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item small"
                                   href="/Account/Profile">
                                    <i class="bi bi-person me-2"></i>
                                    প্রোফাইল
                                </a>
                            </li>
                            @if (User.IsInRole("Admin") ||
                                 User.IsInRole("Editor"))
                            {
                                <li>
                                    <a class="dropdown-item small"
                                       href="/Admin/Dashboard">
                                        <i class="bi bi-speedometer2 me-2"></i>
                                        অ্যাডমিন
                                    </a>
                                </li>
                            }
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="dropdown-item small
                                        text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>
                                        লগআউট
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a href="/Account/Login"
                       class="pb-login-btn">লগইন</a>
                    <a href="/Account/Register"
                       class="pb-register-btn d-none d-sm-inline-flex">
                        নিবন্ধন
                    </a>
                }
            </div>

        </div>
    </header>

    <!-- ══ BREAKING NEWS TICKER ═════════════════════════ -->
    @await Html.PartialAsync("_BreakingNewsTicker")

    <!-- ══ MAIN NAVBAR ══════════════════════════════════ -->
    <nav class="pb-main-nav" id="main-nav">
        <div class="pb-nav-inner">
            @await Html.PartialAsync("_MegaMenu")
            <div class="pb-nav-search">
                <div class="search-box-nav position-relative">
                    <input type="text"
                           id="live-search"
                           class="form-control form-control-sm"
                           placeholder="সংবাদ খুঁজুন..."
                           autocomplete="off"
                           onkeydown="if(event.key==='Enter')submitSearch()" />
                    <button class="pb-search-btn"
                            onclick="submitSearch()">
                        <i class="bi bi-search"></i>
                    </button>
                    <div id="search-suggestions"
                         class="search-dropdown"></div>
                </div>
            </div>
        </div>
    </nav>

    <!-- ══ MAIN CONTENT ═════════════════════════════════ -->
    <main style="min-height:50vh">
        @RenderBody()
    </main>

    <!-- ══ FOOTER ═══════════════════════════════════════ -->
    @await Html.PartialAsync("_Footer")

    <!-- ══ MOBILE OFFCANVAS MENU ════════════════════════ -->
    <div class="offcanvas offcanvas-start" id="mobileMenu">
        <div class="offcanvas-header">
            <h6 class="offcanvas-title fw-bold">মেনু</h6>
            <button type="button" class="btn-close"
                    data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0">
            <ul class="list-unstyled mb-0">
                <li>
                    <a href="/"
                       class="offcanvas-nav-link">হোম</a>
                </li>
                @if (ViewBag.MenuCategories is
                     IEnumerable<NewsPortalPro.DTOs.CategoryDto> menuCats)
                {
                    @foreach (var cat in menuCats)
                    {
                        <li>
                            <a href="/category/@cat.Slug"
                               class="offcanvas-nav-link">
                                @cat.Name
                            </a>
                        </li>
                    }
                }
                <li>
                    <a href="/Epaper"
                       class="offcanvas-nav-link">ই-পেপার</a>
                </li>
            </ul>
        </div>
    </div>

    <!-- ══ NOTIFICATION WIDGET ══════════════════════════ -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="notification-bell-widget position-fixed"
             style="bottom:24px;right:24px;z-index:1000">
            <button id="notif-bell"
                    class="notif-bell-btn position-relative">
                <i class="bi bi-bell-fill"></i>
                <span id="notif-count"
                      class="notif-badge d-none"></span>
            </button>
            <div id="notif-dropdown"
                 class="notif-dropdown d-none">
                <div class="notif-header">
                    <span class="fw-bold small">বিজ্ঞপ্তি</span>
                    <a href="#" id="mark-all-read"
                       class="small text-primary">সব পড়া হয়েছে</a>
                </div>
                <div id="notif-list" class="notif-list"></div>
            </div>
        </div>
    }

    <!-- ══ SCRIPTS ══════════════════════════════════════ -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>