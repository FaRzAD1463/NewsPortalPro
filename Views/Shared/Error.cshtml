@{
    ViewData["Title"] = "ত্রুটি";
    var code = Context.Response.StatusCode;
}

<div class="d-flex align-items-center justify-content-center min-vh-100">
    <div class="text-center p-4">
        <div class="error-code display-1 fw-bold text-primary mb-3">
            @(code == 404 ? "৪০৪" : code == 403 ? "৪০৩" : "৫০০")
        </div>
        <h2 class="mb-3">
            @(code == 404 ? "পৃষ্ঠা পাওয়া যায়নি"
                        : code == 403 ? "প্রবেশাধিকার নেই"
                        : "সার্ভার ত্রুটি")
        </h2>
        <p class="text-muted mb-4">
            @(code == 404 ? "আপনি যে পৃষ্ঠাটি খুঁজছেন সেটি সরানো হয়েছে বা পাওয়া যাচ্ছে না।"
                        : code == 403 ? "এই পৃষ্ঠায় প্রবেশ করার অনুমতি আপনার নেই।"
                        : "দুঃখিত, কিছু একটা ভুল হয়েছে। আবার চেষ্টা করুন।")
        </p>
        <a href="/" class="btn btn-primary px-4">
            <i class="bi bi-house me-2"></i>হোম পেজে ফিরুন
        </a>
    </div>
</div>