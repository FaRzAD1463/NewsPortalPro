@using NewsPortalPro.DTOs
@model List<AdvertisementDto>

@if (Model.Any())
{
    var ad = Model[0];
    <div id="ad-popup-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.6); z-index:2000; align-items:center; justify-content:center;">
        <div style="background:#fff; border-radius:8px; padding:20px; position:relative; max-width:500px; width:90%;">
            <button onclick="document.getElementById('ad-popup-overlay').style.display='none'"
                    style="position:absolute; top:8px; right:8px; background:none; border:none; font-size:1.4rem; cursor:pointer; line-height:1;">
                &times;
            </button>
            @if (!string.IsNullOrEmpty(ad.HtmlCode))
            {
                <iframe src="/ads/render/@ad.Id"
                        sandbox="allow-scripts allow-popups"
                        style="border:0;width:100%;height:250px"
                        scrolling="no"></iframe>
            }
            else if (!string.IsNullOrEmpty(ad.ImageUrl))
            {
                <a href="@ad.TargetUrl" target="_blank" onclick="trackAdClick(@ad.Id)">
                    <img src="@ad.ImageUrl" alt="@ad.Title" style="width:100%;object-fit:contain" />
                </a>
            }
        </div>
    </div>

    <script>
        (function () {
            var STORAGE_KEY = 'adPopupShown';

            if (sessionStorage.getItem(STORAGE_KEY)) return;

            setTimeout(function () {
                var overlay = document.getElementById('ad-popup-overlay');
                if (!overlay) return;

                overlay.style.display = 'flex';
                sessionStorage.setItem(STORAGE_KEY, '1');
            }, 200);
        })();
    </script>
}