@using NewsPortalPro.DTOs
@model PagedResult<NewsListDto>
@{
    var category = ViewBag.Category as CategoryDto;
    ViewData["Title"] = $"{category?.Name} - নিউজপোর্টাল প্রো";
}

<div class="container-fluid px-4 mt-4">

    <!-- Category Header -->
    <div class="category-page-header mb-4"
         style="border-bottom: 3px solid @(category?.ColorCode ?? "#e74c3c")">
        <h1 class="h2 fw-bold pb-2"
            style="color:@(category?.ColorCode ?? "#e74c3c")">
            @category?.Name
        </h1>
    </div>

    <div class="row g-4">
        <div class="col-lg-9">

            <!-- Sort filters -->
            <div class="d-flex gap-2 mb-4 flex-wrap">
                <button class="btn btn-sm btn-primary active"
                        onclick="filterSort('latest', this)">
                    সর্বশেষ
                </button>
                <button class="btn btn-sm btn-outline-secondary"
                        onclick="filterSort('popular', this)">
                    জনপ্রিয়
                </button>
                <button class="btn btn-sm btn-outline-secondary"
                        onclick="filterSort('comments', this)">
                    আলোচিত
                </button>
            </div>

            <!-- News Grid -->
            <div class="row g-4" id="cat-news-grid">
                @if (Model.Items.Any())
                {
                    <!-- Lead story -->
                    <div class="col-12 col-md-6">
                        <div class="pb-news-card pb-news-card-lead">
                            <a href="/news/@Model.Items[0].Slug"
                               class="pb-card-img-link">
                                <div class="pb-card-img-wrapper">
                                    <img src="@(Model.Items[0].FeaturedImage ?? "/images/placeholder.jpg")"
                                         alt="@Model.Items[0].Title"
                                         class="pb-card-img" loading="lazy" />
                                </div>
                            </a>
                            <div class="pb-card-body">
                                <a href="/category/@Model.Items[0].CategorySlug"
                                   class="pb-card-category"
                                   style="color:@(category?.ColorCode ?? "#c0392b")">
                                    @Model.Items[0].CategoryName
                                </a>
                                <h3 class="pb-card-title">
                                    <a href="/news/@Model.Items[0].Slug">@Model.Items[0].Title</a>
                                </h3>
                                <p class="pb-card-summary">@Model.Items[0].Summary</p>
                                <div class="pb-card-meta">
                                    <span><i class="bi bi-person me-1"></i>@Model.Items[0].AuthorName</span>
                                    <span>
                                        <i class="bi bi-clock me-1"></i>
                                        @Model.Items[0].PublishedAt?.ToString("dd MMM yyyy")
                                    </span>
                                    <span><i class="bi bi-eye me-1"></i>@Model.Items[0].ViewCount</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right side list -->
                    <div class="col-12 col-md-6">
                        @foreach (var news in Model.Items.Skip(1).Take(4))
                        {
                            <div class="pb-news-card-horizontal">
                                <a href="/news/@news.Slug" class="pb-card-img-link">
                                    <div class="pb-card-img-wrapper">
                                        <img src="@(news.FeaturedImage ?? "/images/placeholder.jpg")"
                                             alt="@news.Title"
                                             class="pb-card-img" loading="lazy" />
                                    </div>
                                </a>
                                <div class="pb-card-body flex-grow-1">
                                    <h3 class="pb-card-title">
                                        <a href="/news/@news.Slug">@news.Title</a>
                                    </h3>
                                    <p class="pb-card-summary">@news.Summary</p>
                                    <div class="pb-card-meta">
                                        <span>
                                            <i class="bi bi-clock me-1"></i>
                                            @news.PublishedAt?.ToString("dd MMM yyyy")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Rest in 4-column grid -->
                    @foreach (var news in Model.Items.Skip(5))
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            @await Html.PartialAsync("_NewsCard", news)
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-newspaper fs-1 text-muted"></i>
                        <p class="text-muted mt-3">এই বিভাগে কোনো সংবাদ নেই।</p>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-5">
                    <ul class="pagination justify-content-center">
                        @if (Model.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   href="/category/@(category?.Slug)/@(Model.Page - 1)">
                                    পূর্ববর্তী
                                </a>
                            </li>
                        }
                        @for (int i = Math.Max(1, Model.Page - 2);
                                            i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link"
                                   href="/category/@(category?.Slug)/@(i)">@i</a>
                            </li>
                        }
                        @if (Model.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   href="/category/@(category?.Slug)/@(Model.Page + 1)">
                                    পরবর্তী
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }

        </div>

        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="sticky-sidebar">
                @if (ViewBag.SidebarAds != null)
                {
                    foreach (var ad in (List<AdvertisementDto>)ViewBag.SidebarAds)
                    {
                        <div class="sidebar-widget ad-widget mb-4">
                            @if (!string.IsNullOrEmpty(ad.ImageUrl))
                            {
                                <a href="@ad.TargetUrl" target="_blank">
                                    <img src="@ad.ImageUrl" alt="@ad.Title"
                                         class="img-fluid rounded w-100" />
                                </a>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function filterSort(sort, btn) {
            document.querySelectorAll('.btn[onclick^="filterSort"]').forEach(b => {
                b.className = 'btn btn-sm btn-outline-secondary';
            });
            btn.className = 'btn btn-sm btn-primary active';

            const slug = '@category?.Slug';
            const res = await fetch(`/api/news?categorySlug=${slug}&sort=${sort}&pageSize=12&page=1`);
            const data = await res.json();
            const grid = document.getElementById('cat-news-grid');
            grid.innerHTML = '';

            if (!data.items || data.items.length === 0) {
                grid.innerHTML = '<div class="col-12 text-center py-5 text-muted">কোনো সংবাদ নেই</div>';
                return;
            }

            data.items.forEach((n, i) => {
                if (i === 0) {
                    grid.innerHTML += `
                    <div class="col-12 col-md-6">
                        <div class="pb-news-card pb-news-card-lead">
                            <a href="/news/${n.slug}" class="pb-card-img-link">
                                <div class="pb-card-img-wrapper">
                                    <img src="${n.featuredImage || '/images/placeholder.jpg'}"
                                         alt="${n.title}" class="pb-card-img" loading="lazy" />
                                </div>
                            </a>
                            <div class="pb-card-body">
                                <span class="pb-card-category"
                                      style="color:${n.categoryColor || '#c0392b'}">
                                    ${n.categoryName}
                                </span>
                                <h3 class="pb-card-title">
                                    <a href="/news/${n.slug}">${n.title}</a>
                                </h3>
                                <p class="pb-card-summary">${n.summary || ''}</p>
                                <div class="pb-card-meta">
                                    <span>
                                        <i class="bi bi-clock me-1"></i>
                                        ${n.publishedAt ? new Date(n.publishedAt)
                                            .toLocaleDateString('bn-BD') : ''}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>`;
                } else if (i >= 1 && i <= 4) {
                    if (i === 1) grid.innerHTML += '<div class="col-12 col-md-6">';
                    grid.innerHTML += `
                        <div class="pb-news-card-horizontal">
                            <a href="/news/${n.slug}" class="pb-card-img-link">
                                <div class="pb-card-img-wrapper">
                                    <img src="${n.featuredImage || '/images/placeholder.jpg'}"
                                         alt="${n.title}" class="pb-card-img" loading="lazy" />
                                </div>
                            </a>
                            <div class="pb-card-body flex-grow-1">
                                <h3 class="pb-card-title">
                                    <a href="/news/${n.slug}">${n.title}</a>
                                </h3>
                                <p class="pb-card-summary">${n.summary || ''}</p>
                                <div class="pb-card-meta">
                                    <span>
                                        <i class="bi bi-clock me-1"></i>
                                        ${n.publishedAt ? new Date(n.publishedAt)
                                            .toLocaleDateString('bn-BD') : ''}
                                    </span>
                                </div>
                            </div>
                        </div>`;
                    if (i === 4) grid.innerHTML += '</div>';
                } else {
                    grid.innerHTML += `
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="news-card card h-100 border-0 shadow-sm">
                            <a href="/news/${n.slug}">
                                <img src="${n.featuredImage || '/images/placeholder.jpg'}"
                                     class="card-img-top" alt="${n.title}"
                                     style="height:175px;object-fit:cover" loading="lazy" />
                            </a>
                            <div class="card-body p-3">
                                <span class="category-badge small"
                                      style="background:${n.categoryColor || '#6c757d'}">
                                    ${n.categoryName}
                                </span>
                                <h6 class="card-title mt-2 small fw-semibold">
                                    <a href="/news/${n.slug}"
                                       class="text-dark text-decoration-none">${n.title}</a>
                                </h6>
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>
                                    ${n.publishedAt ? new Date(n.publishedAt)
                                        .toLocaleDateString('bn-BD') : ''}
                                </small>
                            </div>
                        </div>
                    </div>`;
                }
            });
        }
    </script>
}