@using NewsPortalPro.DTOs
@using NewsPortalPro.Models
@model NewsPortalPro.DTOs.PagedResult<NewsPortalPro.DTOs.NewsListDto>
@{
    var cat = ViewBag.Category as CategoryDto;
    var sort = ViewBag.Sort as string ?? "latest";
    var trending = ViewBag.Trending as List<NewsListDto>
               ?? new List<NewsListDto>();

    ViewData["Title"] = cat?.Name ?? "বিভাগ";
}

<div class="pb-page-container">
    <div class="row g-4 mt-1">

        <!-- ══ MAIN CONTENT ═══════════════════════════════════ -->
        <div class="col-lg-9">

            <!-- Category header -->
            <div class="cat-page-header mb-3">
                <h1 class="cat-page-title"
                    style="border-left:4px solid #111;padding-left:10px">
                    @cat?.Name
                </h1>
                <hr class="mt-2 mb-0" style="border-color:#e5e5e5;opacity:1" />
            </div>

            <!-- Sort tabs -->
            <div class="d-flex gap-2 mb-4">
                <a href="/category/@cat?.Slug?sort=latest"
                   class="btn btn-sm @(sort == "latest" || sort == null
                                      ? "btn-dark" : "btn-outline-secondary")">
                    সর্বশেষ
                </a>
                <a href="/category/@cat?.Slug?sort=popular"
                   class="btn btn-sm @(sort == "popular"
                                      ? "btn-dark" : "btn-outline-secondary")">
                    জনপ্রিয়
                </a>
                <a href="/category/@cat?.Slug?sort=comments"
                   class="btn btn-sm @(sort == "comments"
                                      ? "btn-dark" : "btn-outline-secondary")">
                    আলোচিত
                </a>
            </div>

            @if (!Model.Items.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-newspaper fs-1 text-muted"></i>
                    <p class="text-muted mt-3">এই বিভাগে কোনো সংবাদ নেই।</p>
                    <a href="/" class="btn btn-outline-secondary btn-sm">
                        হোমে ফিরুন
                    </a>
                </div>
            }
            else
            {
                <!-- ── Top 4 cards grid ─────────────────────────── -->
                <div class="row g-3 mb-4">
                    @foreach (var n in Model.Items.Take(4))
                    {
                        <div class="col-6 col-md-3">
                            <div class="cat-top-card">
                                <a href="/news/@n.Slug"
                                   class="cat-top-img-link">
                                    <img src="@(n.FeaturedImage
                                                                                     ?? "/images/placeholder.jpg")"
                                 alt="@n.Title"
                                 class="cat-top-img"
                                 loading="lazy"
                                 onerror="this.src='/images/placeholder.jpg'" />
                        </a>
                        <h6 class="cat-top-title mt-2">
                            <a href="/news/@n.Slug"
                               class="text-dark text-decoration-none">
                                @n.Title
                            </a>
                        </h6>
                        @if (!string.IsNullOrEmpty(n.Summary))
                                {
                                    <p class="cat-top-summary">@n.Summary</p>
                                }
                                <div class="pb-meta-sm">
                                    <i class="bi bi-clock me-1"></i>
                                    @n.PublishedAt?.ToString("dd MMM yyyy")
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <hr style="border-color:#e5e5e5;opacity:1" />

                <!-- ── List style items ────────────────────────── -->
                <div id="cat-news-list">
                    @foreach (var n in Model.Items.Skip(4))
                    {
                        <div class="cat-list-item">
                            <a href="/news/@n.Slug"
                               class="cat-list-thumb-link flex-shrink-0">
                                <img src="@(n.FeaturedImage
                                                                             ?? "/images/placeholder.jpg")"
                             alt="@n.Title"
                             class="cat-list-thumb"
                             loading="lazy"
                             onerror="this.src='/images/placeholder.jpg'" />
                    </a>
                    <div class="cat-list-body">
                        <h5 class="cat-list-title">
                            <a href="/news/@n.Slug"
                               class="text-dark text-decoration-none">
                                @n.Title
                            </a>
                        </h5>
                        @if (!string.IsNullOrEmpty(n.Summary))
                                {
                                    <p class="cat-list-summary">@n.Summary</p>
                                }
                                <div class="pb-meta-sm d-flex gap-3">
                                    @if (!string.IsNullOrEmpty(n.AuthorName))
                                    {
                                        <span>
                                            <i class="bi bi-person me-1"></i>
                                            @n.AuthorName
                                        </span>
                                    }
                                    <span>
                                        <i class="bi bi-clock me-1"></i>
                                        @n.PublishedAt?.ToString("dd MMM yyyy")
                                    </span>
                                    @if (n.ViewCount > 0)
                                    {
                                        <span>
                                            <i class="bi bi-eye me-1"></i>
                                            @n.ViewCount
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- ── Load more ───────────────────────────────── -->
                @if (Model.TotalPages > 1)
                {
                    <div class="text-center mt-4" id="load-more-wrap">
                        <button class="btn btn-outline-secondary px-5"
                                id="load-more-btn"
                                data-page="2"
                                data-slug="@cat?.Slug"
                                data-sort="@sort"
                                onclick="loadMore(this)">
                            আরও দেখুন
                            <i class="bi bi-chevron-down ms-1"></i>
                        </button>
                    </div>
                }
            }

        </div>

        <!-- ══ RIGHT SIDEBAR ══════════════════════════════════ -->
        <div class="col-lg-3">
            <div class="pb-sidebar">

                <!-- Trending in this category -->
                @if (trending.Any())
                {
                    <div class="pb-widget mb-4">
                        <div class="pb-section-hdr mb-3">
                            <h6 class="pb-sec-title mb-0">
                                <i class="bi bi-fire text-danger me-1"></i>
                                সর্বাধিক পঠিত
                            </h6>
                        </div>
                        @foreach (var (n, i) in trending
                                            .Select((x, idx) => (x, idx + 1)))
                        {
                            <div class="pb-trending-item">
                                <span class="pb-trending-num">@i</span>
                                <div class="flex-grow-1">
                                    <a href="/news/@n.Slug"
                                       class="pb-trending-title text-dark
                                                  text-decoration-none">
                                        @n.Title
                                    </a>
                                    <div class="pb-meta-sm mt-1">
                                        <i class="bi bi-clock me-1"></i>
                                        @n.PublishedAt?.ToString("dd MMM")
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Sidebar ads -->
                @if (ViewBag.SidebarAds != null)
                {
                    foreach (var ad in
                    (IEnumerable<AdvertisementDto>)ViewBag.SidebarAds)
                    {
                        <div class="pb-widget mb-3 p-0 text-center overflow-hidden">
                            @if (!string.IsNullOrEmpty(ad.HtmlCode))
                            {
                                @Html.Raw(ad.HtmlCode)
                            }
                            else if (!string.IsNullOrEmpty(ad.ImageUrl))
                            {
                                <a href="@ad.TargetUrl" target="_blank">
                                    <img src="@ad.ImageUrl"
                                         class="img-fluid w-100" />
                                </a>
                            }
                        </div>
                    }
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        var _totalPages = @Model.TotalPages;

        async function loadMore(btn) {
            var page = parseInt(btn.dataset.page);
            var slug = btn.dataset.slug;
            var sort = btn.dataset.sort;

            btn.disabled = true;
            btn.innerHTML =
                '<span class="spinner-border spinner-border-sm me-2"></span>' +
                'লোড হচ্ছে...';

            try {
                var res  = await fetch(
                    '/category/' + slug + '/more?page=' + page +
                    '&sort=' + sort);
                var html = await res.text();

                document.getElementById('cat-news-list')
                    .insertAdjacentHTML('beforeend', html);

                btn.dataset.page = page + 1;

                if (page + 1 > _totalPages) {
                    document.getElementById('load-more-wrap')
                        .style.display = 'none';
                } else {
                    btn.disabled = false;
                    btn.innerHTML =
                        'আরও দেখুন <i class="bi bi-chevron-down ms-1"></i>';
                }
            } catch (e) {
                btn.disabled = false;
                btn.innerHTML =
                    'আরও দেখুন <i class="bi bi-chevron-down ms-1"></i>';
                toastr.error('লোড ব্যর্থ হয়েছে');
            }
        }
    </script>
}