@using NewsPortalPro.DTOs
@model PagedResult<NewsListDto>
@{
    var category = ViewBag.Category as CategoryDto;
    ViewData["Title"] = $"{category?.Name} - নিউজপোর্টাল প্রো";
}

<div class="container-fluid px-4 mt-4">

    <!-- Category Header -->
    <div class="category-page-header mb-4"
         style="border-bottom: 3px solid @(category?.ColorCode ?? "#e74c3c")">
        <h1 class="h2 fw-bold pb-2"
            style="color:@(category?.ColorCode ?? "#e74c3c")">
            @category?.Name
        </h1>
    </div>

    <div class="row g-4">
        <div class="col-lg-9">

            <!-- Sort filters -->
            <div class="d-flex gap-2 mb-4 flex-wrap">
                <button class="btn btn-sm btn-primary active"
                        onclick="filterSort('latest', this)">
                    সর্বশেষ
                </button>
                <button class="btn btn-sm btn-outline-secondary"
                        onclick="filterSort('popular', this)">
                    জনপ্রিয়
                </button>
                <button class="btn btn-sm btn-outline-secondary"
                        onclick="filterSort('comments', this)">
                    আলোচিত
                </button>
            </div>

            <!-- News Grid -->
            <div class="row g-4" id="cat-news-grid">
                @if (Model.Items.Any())
                {
                    <!-- Lead story -->
                    <div class="col-12">
                        <div class="d-md-flex gap-4 pb-4 border-bottom">
                            <div class="flex-shrink-0 mb-3 mb-md-0">
                                <a href="/news/@Model.Items[0].Slug">
                                    <img src="@(Model.Items[0].FeaturedImage ?? "/images/placeholder.jpg")"
                                         alt="@Model.Items[0].Title"
                                         class="rounded"
                                         style="width:320px;height:220px;object-fit:cover"
                                         loading="lazy" />
                                </a>
                            </div>
                            <div>
                                <span class="category-badge mb-2 d-inline-block"
                                      style="background:@(category?.ColorCode ?? "#6c757d")">
                                    @Model.Items[0].CategoryName
                                </span>
                                <h3 class="fw-bold">
                                    <a href="/news/@Model.Items[0].Slug"
                                       class="text-dark text-decoration-none">
                                        @Model.Items[0].Title
                                    </a>
                                </h3>
                                <p class="text-muted">@Model.Items[0].Summary</p>
                                <small class="text-muted">
                                    <i class="bi bi-person me-1"></i>@Model.Items[0].AuthorName
                                    <span class="mx-2">•</span>
                                    <i class="bi bi-clock me-1"></i>
                                    @Model.Items[0].PublishedAt?.ToString("dd MMM yyyy")
                                    <span class="mx-2">•</span>
                                    <i class="bi bi-eye me-1"></i>@Model.Items[0].ViewCount
                                </small>
                            </div>
                        </div>
                    </div>

                    <!-- Rest in grid -->
                    @foreach (var news in Model.Items.Skip(1))
                    {
                        <div class="col-md-6 col-lg-4">
                            @await Html.PartialAsync("_NewsCard", news)
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-newspaper fs-1 text-muted"></i>
                        <p class="text-muted mt-3">এই বিভাগে কোনো সংবাদ নেই।</p>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-5">
                    <ul class="pagination justify-content-center">
                        @if (Model.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   href="/category/@(category?.Slug)/@(Model.Page - 1)">
                                    পূর্ববর্তী
                                </a>
                            </li>
                        }
                        @for (int i = Math.Max(1, Model.Page - 2);
                                            i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link"
                                   href="/category/@(category?.Slug)/@(i)">@i</a>
                            </li>
                        }
                        @if (Model.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   href="/category/@(category?.Slug)/@(Model.Page + 1)">
                                    পরবর্তী
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }

        </div>

        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="sticky-sidebar">
                @if (ViewBag.SidebarAds != null)
                {
                    foreach (var ad in (List<AdvertisementDto>)ViewBag.SidebarAds)
                    {
                        <div class="sidebar-widget ad-widget mb-4">
                            @if (!string.IsNullOrEmpty(ad.ImageUrl))
                            {
                                <a href="@ad.TargetUrl" target="_blank">
                                    <img src="@ad.ImageUrl" alt="@ad.Title"
                                         class="img-fluid rounded w-100" />
                                </a>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function filterSort(sort, btn) {
            document.querySelectorAll('.btn[onclick^="filterSort"]').forEach(b => {
                b.className = 'btn btn-sm btn-outline-secondary';
            });
            btn.className = 'btn btn-sm btn-primary active';

            const slug = '@category?.Slug';
            const res = await fetch(`/api/news?categorySlug=${slug}&sort=${sort}&pageSize=12&page=1`);
            const data = await res.json();
            const grid = document.getElementById('cat-news-grid');
            grid.innerHTML = '';

            if (!data.items || data.items.length === 0) {
                grid.innerHTML = '<div class="col-12 text-center py-5 text-muted">কোনো সংবাদ নেই</div>';
                return;
            }

            data.items.forEach((n, i) => {
                if (i === 0) {
                    grid.innerHTML += `
                    <div class="col-12">
                        <div class="d-md-flex gap-4 pb-4 border-bottom">
                            <div class="flex-shrink-0 mb-3 mb-md-0">
                                <a href="/news/${n.slug}">
                                    <img src="${n.featuredImage || '/images/placeholder.jpg'}"
                                         alt="${n.title}" class="rounded"
                                         style="width:280px;height:190px;object-fit:cover" />
                                </a>
                            </div>
                            <div>
                                <h4 class="fw-bold">
                                    <a href="/news/${n.slug}"
                                       class="text-dark text-decoration-none">${n.title}</a>
                                </h4>
                                <p class="text-muted small">${n.summary || ''}</p>
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>
                                    ${n.publishedAt ? new Date(n.publishedAt)
                                        .toLocaleDateString('bn-BD') : ''}
                                </small>
                            </div>
                        </div>
                    </div>`;
                } else {
                    grid.innerHTML += `
                    <div class="col-md-6 col-lg-4">
                        <div class="news-card card h-100 border-0 shadow-sm">
                            <a href="/news/${n.slug}">
                                <img src="${n.featuredImage || '/images/placeholder.jpg'}"
                                     class="card-img-top" alt="${n.title}"
                                     style="height:175px;object-fit:cover" loading="lazy" />
                            </a>
                            <div class="card-body p-3">
                                <span class="category-badge small"
                                      style="background:${n.categoryColor||'#6c757d'}">
                                    ${n.categoryName}
                                </span>
                                <h6 class="card-title mt-2 small fw-semibold">
                                    <a href="/news/${n.slug}"
                                       class="text-dark text-decoration-none">${n.title}</a>
                                </h6>
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>
                                    ${n.publishedAt ? new Date(n.publishedAt)
                                        .toLocaleDateString('bn-BD') : ''}
                                </small>
                            </div>
                        </div>
                    </div>`;
                }
            });
        }
    </script>
}