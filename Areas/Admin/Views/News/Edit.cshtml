@using NewsPortalPro.DTOs
@using NewsPortalPro.Models
@model NewsPortalPro.DTOs.UpdateNewsDto
@{
    ViewData["Title"] = "সংবাদ সম্পাদনা";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">সংবাদ সম্পাদনা</h4>
    <div class="d-flex gap-2">
        @if (ViewBag.NewsSlug != null)
        {
            <a href="/news/@ViewBag.NewsSlug" target="_blank"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-eye me-1"></i>সাইটে দেখুন
            </a>
        }
        <a href="/Admin/News"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>ফিরে যান
        </a>
    </div>
</div>

<form method="post" enctype="multipart/form-data"
      asp-action="Edit" asp-route-id="@Model.Id">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row g-4">

        <!-- ── Left: Main content ────────────────────────── -->
        <div class="col-lg-8">

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            শিরোনাম <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title"
                               class="form-control form-control-lg"
                               required />
                        <span asp-validation-for="Title"
                              class="text-danger small"></span>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-medium">
                            উপশিরোনাম
                        </label>
                        <input asp-for="Subtitle"
                               class="form-control" />
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <label class="form-label fw-medium">
                        কন্টেন্ট <span class="text-danger">*</span>
                    </label>
                    <textarea asp-for="Content"
                              id="news-content"
                              class="form-control"
                              rows="20"></textarea>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <label class="form-label fw-medium">
                        সারসংক্ষেপ
                    </label>
                    <textarea asp-for="Summary"
                              class="form-control"
                              rows="3"></textarea>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent fw-medium">
                    SEO সেটিংস
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small">Meta Title</label>
                        <input asp-for="MetaTitle"
                               class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">
                            Meta Description
                        </label>
                        <textarea asp-for="MetaDescription"
                                  class="form-control"
                                  rows="2"></textarea>
                    </div>
                    <div class="mb-0">
                        <label class="form-label small">
                            Meta Keywords
                        </label>
                        <input asp-for="MetaKeywords"
                               class="form-control" />
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Right: Settings ──────────────────────────── -->
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent fw-medium">
                    প্রকাশ সেটিংস
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small">স্ট্যাটাস</label>
                        <select asp-for="Status" class="form-select">
                            <option value="0">ড্রাফট</option>
                            <option value="1">প্রকাশিত</option>
                            <option value="2">নির্ধারিত</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">বিভাগ</label>
                        <select asp-for="CategoryId"
                                class="form-select" required>
                            <option value="">বিভাগ নির্বাচন করুন</option>
                            @if (ViewBag.Categories is
                                                        Microsoft.AspNetCore.Mvc.Rendering
                                                        .SelectList cats)
                            {
                                @foreach (var item in cats)
                                {
                                    @if (item.Value ==
                                                                Model.CategoryId.ToString())
                                    {
                                        <option value="@item.Value"
                                                selected>
                                            @item.Text
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">
                                            @item.Text
                                        </option>
                                    }
                                }
                            }
                        </select>
                        <span asp-validation-for="CategoryId"
                              class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">ট্যাগ</label>
                        <input asp-for="TagsString"
                               class="form-control"
                               placeholder="ট্যাগ, কমা দিয়ে আলাদা করুন" />
                        <small class="text-muted">
                            যেমন: ক্রিকেট, খেলাধুলা, বাংলাদেশ
                        </small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">
                            ভিডিও URL (ঐচ্ছিক)
                        </label>
                        <input asp-for="VideoUrl"
                               class="form-control" />
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsFeatured"
                                   class="form-check-input"
                                   type="checkbox" />
                            <label class="form-check-label small">
                                ফিচার্ড সংবাদ
                            </label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsBreaking"
                                   class="form-check-input"
                                   type="checkbox" />
                            <label class="form-check-label small">
                                ব্রেকিং নিউজ
                            </label>
                        </div>
                    </div>
                    <div class="mb-0">
                        <div class="form-check form-switch">
                            <input asp-for="AllowComments"
                                   class="form-check-input"
                                   type="checkbox" />
                            <label class="form-check-label small">
                                মন্তব্য অনুমতি
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Featured Image -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent fw-medium">
                    ফিচার্ড ছবি
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.FeaturedImageUrl))
                    {
                        <img id="featured-preview"
                             src="@Model.FeaturedImageUrl"
                             class="img-fluid rounded mb-2"
                             style="max-height:140px;
                                        object-fit:cover;width:100%" />
                    }
                    else
                    {
                        <img id="featured-preview"
                             src=""
                             class="img-fluid rounded d-none mb-2"
                             style="max-height:140px;
                                        object-fit:cover;width:100%" />
                    }
                    <input type="file" name="featuredImage"
                           class="form-control form-control-sm mb-2"
                           accept="image/*"
                           onchange="previewImage(
                               this,'featured-preview')" />
                    <input type="hidden" asp-for="FeaturedImageUrl" />
                    <input asp-for="FeaturedImageAlt"
                           class="form-control form-control-sm mb-2"
                           placeholder="ছবির Alt টেক্সট" />
                    <input asp-for="FeaturedImageCaption"
                           class="form-control form-control-sm"
                           placeholder="ছবির ক্যাপশন" />
                </div>
            </div>

            <!-- Gallery Images -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent fw-medium">
                    গ্যালারি ছবি
                    <small class="text-muted fw-normal ms-1">
                        — ক্লিক করলে এডিটরে যোগ হবে
                    </small>
                </div>
                <div class="card-body">
                    <input type="file"
                           id="gallery-upload-input"
                           accept="image/*" multiple
                           class="form-control form-control-sm mb-2"
                           onchange="uploadGalleryImages(this.files)" />
                    <div id="gallery-preview"
                         class="d-flex flex-wrap gap-2 mt-1">
                    </div>
                    <small class="text-muted d-block mt-2">
                        একসাথে একাধিক ছবি নির্বাচন করুন।
                        ছবিতে ক্লিক করলে কন্টেন্টে যোগ হবে।
                    </small>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-2"></i>
                    আপডেট করুন
                </button>
                <a href="/Admin/News"
                   class="btn btn-outline-secondary">বাতিল</a>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.3/tinymce.min.js"></script>
    <script>
        var _token = document.querySelector(
            'input[name="__RequestVerificationToken"]')?.value ?? '';

        tinymce.init({
            selector:  '#news-content',
            height:    500,
            menubar:   true,
            plugins: [
                'advlist','autolink','lists','link','image',
                'charmap','preview','anchor','searchreplace',
                'visualblocks','code','fullscreen','insertdatetime',
                'media','table','help','wordcount'
            ],
            toolbar:
                'undo redo | blocks | ' +
                'bold italic underline strikethrough | ' +
                'alignleft aligncenter alignright alignjustify | ' +
                'bullist numlist outdent indent | ' +
                'link image media table | ' +
                'forecolor backcolor | removeformat | ' +
                'code fullscreen | help',
            image_title:       true,
            automatic_uploads: true,
            file_picker_types: 'image',
            images_upload_handler: async function(blobInfo) {
                var fd = new FormData();
                fd.append('file', blobInfo.blob(), blobInfo.filename());
                fd.append('__RequestVerificationToken', _token);
                var res  = await fetch('/Admin/News/UploadImage',
                    { method: 'POST', body: fd });
                var data = await res.json();
                if (!data.url) throw new Error('Upload failed');
                return data.url;
            },
            content_style:
                'body{font-family:Noto Sans Bengali,sans-serif;' +
                'font-size:16px;line-height:1.8;color:#222;padding:12px}' +
                'img{max-width:100%;height:auto}' +
                'p{margin-bottom:14px}'
        });

        function previewImage(input, previewId) {
            var p = document.getElementById(previewId);
            if (!p || !input.files || !input.files[0]) return;
            var r = new FileReader();
            r.onload = function(e) {
                p.src = e.target.result;
                p.classList.remove('d-none');
            };
            r.readAsDataURL(input.files[0]);
        }

        async function uploadGalleryImages(files) {
            if (!files || !files.length) return;
            var gallery = document.getElementById('gallery-preview');

            for (var i = 0; i < files.length; i++) {
                var fd = new FormData();
                fd.append('file', files[i]);
                fd.append('__RequestVerificationToken', _token);

                var wrap = document.createElement('div');
                wrap.className =
                    'position-relative d-flex align-items-center ' +
                    'justify-content-center bg-light rounded';
                wrap.style.cssText =
                    'width:80px;height:60px;flex-shrink:0';
                wrap.innerHTML =
                    '<div class="spinner-border spinner-border-sm ' +
                    'text-secondary"></div>';
                gallery.appendChild(wrap);

                try {
                    var res  = await fetch('/Admin/News/UploadImage',
                        { method: 'POST', body: fd });
                    var data = await res.json();

                    if (data.url) {
                        var url = data.url;
                        wrap.innerHTML = '';
                        wrap.className = 'position-relative';
                        wrap.style.cssText =
                            'width:80px;height:60px;flex-shrink:0';

                        var img = document.createElement('img');
                        img.src = url;
                        img.style.cssText =
                            'width:80px;height:60px;object-fit:cover;' +
                            'border-radius:4px;cursor:pointer;' +
                            'border:2px solid #e0e0e0;' +
                            'transition:border-color .2s';
                        img.title = 'ক্লিক করলে এডিটরে যোগ হবে';

                        img.addEventListener('click', function() {
                            var u = this.src;
                            if (typeof tinymce !== 'undefined' &&
                                tinymce.activeEditor) {
                                tinymce.activeEditor.insertContent(
                                    '<figure style="text-align:center;' +
                                    'margin:16px 0"><img src="' + u +
                                    '" style="max-width:100%;height:auto"' +
                                    ' alt="" /><figcaption style="' +
                                    'font-size:.85rem;color:#777;' +
                                    'margin-top:4px">ছবির ক্যাপশন' +
                                    '</figcaption></figure>');
                                this.style.borderColor = '#c0392b';
                                toastr.success('ছবি এডিটরে যোগ হয়েছে');
                            } else {
                                navigator.clipboard.writeText(u)
                                    .then(function() {
                                        toastr.info('URL কপি হয়েছে');
                                    });
                            }
                        });

                        var rb = document.createElement('button');
                        rb.type = 'button';
                        rb.innerHTML = '×';
                        rb.style.cssText =
                            'position:absolute;top:-6px;right:-6px;' +
                            'width:18px;height:18px;border-radius:50%;' +
                            'background:#dc3545;color:#fff;border:none;' +
                            'font-size:11px;cursor:pointer;display:flex;' +
                            'align-items:center;justify-content:center;' +
                            'line-height:1;z-index:1';
                        rb.onclick = function() { wrap.remove(); };

                        wrap.appendChild(img);
                        wrap.appendChild(rb);
                        toastr.success('ছবি আপলোড সফল');
                    } else {
                        wrap.innerHTML =
                            '<small class="text-danger p-1">ব্যর্থ</small>';
                    }
                } catch {
                    wrap.innerHTML =
                        '<small class="text-danger p-1">ত্রুটি</small>';
                }
            }
            document.getElementById('gallery-upload-input').value = '';
        }
    </script>
}