@using NewsPortalPro.DTOs
@using NewsPortalPro.Models
@model NewsPortalPro.DTOs.PagedResult<NewsPortalPro.DTOs.NewsListDto>

@{
    ViewData["Title"] = "সংবাদ ব্যবস্থাপনা";
    var filter = ViewBag.Filter as AdminNewsFilterDto ?? new AdminNewsFilterDto();

    var isDraft = filter.Status == NewsStatus.Draft;
    var isPublished = filter.Status == NewsStatus.Published;
    var isScheduled = filter.Status == NewsStatus.Scheduled;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">সর্বশেষ সংবাদ</h4>
    <a href="/Admin/News/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>নতুন সংবাদ
    </a>
</div>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" name="Search"
                       value="@filter.Search"
                       class="form-control form-control-sm"
                       placeholder="শিরোনাম খুঁজুন..." />
            </div>

            <div class="col-md-3">
                <select name="Status" class="form-select form-select-sm">
                    <option value="">সব স্ট্যাটাস</option>

                    <option value="0" selected="@(isDraft ? "selected" : null)">
                        ড্রাফট
                    </option>

                    <option value="1" selected="@(isPublished ? "selected" : null)">
                        প্রকাশিত
                    </option>

                    <option value="2" selected="@(isScheduled ? "selected" : null)">
                        নির্ধারিত
                    </option>
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>খুঁজুন
                </button>
            </div>

            <div class="col-md-2">
                <a href="/Admin/News" class="btn btn-outline-secondary btn-sm w-100">
                    রিসেট
                </a>
            </div>
        </form>
    </div>
</div>

<!-- News Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">

        @if (!Model.Items.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-newspaper fs-1 text-muted"></i>
                <p class="text-muted mt-3">কোনো সংবাদ পাওয়া যায়নি।</p>
                <a href="/Admin/News/Create" class="btn btn-primary btn-sm">
                    প্রথম সংবাদ তৈরি করুন
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px">#</th>
                            <th>শিরোনাম</th>
                            <th style="width:120px">বিভাগ</th>
                            <th style="width:100px">স্ট্যাটাস</th>
                            <th style="width:80px">ভিউ</th>
                            <th style="width:110px">তারিখ</th>
                            <th style="width:160px" class="text-center">অ্যাকশন</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var news in Model.Items)
                        {
                            <tr>

                                <!-- Thumbnail -->
                                <td>
                                    @if (!string.IsNullOrEmpty(news.FeaturedImage))
                                    {
                                        <img src="@news.FeaturedImage"
                                             class="rounded"
                                             style="width:48px;height:36px;object-fit:cover" />
                                    }
                                    else
                                    {
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center"
                                             style="width:48px;height:36px">
                                            <i class="bi bi-image text-muted small"></i>
                                        </div>
                                    }
                                </td>

                                <!-- Title -->
                                <td>
                                    <div class="fw-medium small text-truncate"
                                         style="max-width:320px"
                                         title="@news.Title">
                                        @news.Title
                                    </div>

                                    <div class="d-flex gap-2 mt-1">
                                        <span class="text-muted" style="font-size:11px">
                                            <i class="bi bi-person me-1"></i>
                                            @news.AuthorName
                                        </span>

                                        @if (news.IsBreaking)
                                        {
                                            <span class="badge bg-danger" style="font-size:10px">
                                                ব্রেকিং
                                            </span>
                                        }

                                        @if (news.IsFeatured)
                                        {
                                            <span class="badge bg-warning text-dark" style="font-size:10px">
                                                ফিচার্ড
                                            </span>
                                        }
                                    </div>
                                </td>

                                <!-- Category -->
                                <td>
                                    <span class="badge rounded-pill"
                                          style="background:@(news.CategoryColor ?? "#6c757d");font-size:11px">
                                        @news.CategoryName
                                    </span>
                                </td>

                                <!-- Status -->
                                <td>
                                    @if (news.PublishedAt.HasValue && news.PublishedAt <= DateTime.UtcNow)
                                    {
                                        <span class="badge bg-success" style="font-size:11px">প্রকাশিত</span>
                                    }
                                    else if (news.PublishedAt.HasValue)
                                    {
                                        <span class="badge bg-info" style="font-size:11px">নির্ধারিত</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" style="font-size:11px">ড্রাফট</span>
                                    }
                                </td>

                                <!-- Views -->
                                <td class="text-muted small">
                                    <i class="bi bi-eye me-1"></i>
                                    @news.ViewCount
                                </td>

                                <!-- Date -->
                                <td class="text-muted small">
                                    @(news.PublishedAt?.ToString("dd MMM yy") ?? "—")
                                </td>

                                <!-- Actions -->
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">

                                        <a href="/news/@news.Slug"
                                           target="_blank"
                                           class="btn btn-outline-secondary btn-sm">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a href="/Admin/News/Edit/@news.Id"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        @if (!news.PublishedAt.HasValue || news.PublishedAt > DateTime.UtcNow)
                                        {
                                            <button class="btn btn-outline-success btn-sm"
                                                    onclick="publishNews(@news.Id)">
                                                <i class="bi bi-check-circle"></i>
                                            </button>
                                        }

                                        <button class="btn btn-outline-danger btn-sm"
                                                onclick="deleteNews(@news.Id, '@news.Title.Replace("'", "\\'")')">
                                            <i class="bi bi-trash"></i>
                                        </button>

                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="p-3 border-top">
                    <nav>
                        <ul class="pagination pagination-sm justify-content-center mb-0">

                            @if (Model.HasPreviousPage)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                       href="?page=@(Model.Page - 1)&Search=@filter.Search&Status=@filter.Status">
                                        পূর্ববর্তী
                                    </a>
                                </li>
                            }

                            @for (int i = Math.Max(1, Model.Page - 2);
                                                i <= Math.Min(Model.TotalPages, Model.Page + 2);
                                                i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link"
                                       href="?page=@i&Search=@filter.Search&Status=@filter.Status">
                                        @i
                                    </a>
                                </li>
                            }

                            @if (Model.HasNextPage)
                            {
                                <li class="page-item">
                                    <a class="page-link"
                                       href="?page=@(Model.Page + 1)&Search=@filter.Search&Status=@filter.Status">
                                        পরবর্তী
                                    </a>
                                </li>
                            }

                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

<!-- Summary -->
<div class="mt-3 text-muted small">
    মোট @Model.TotalCount টি সংবাদ পাওয়া গেছে।
    পৃষ্ঠা @Model.Page / @Model.TotalPages
</div>

<!-- Delete form -->
<form id="delete-form" method="post" style="display:none">
    @Html.AntiForgeryToken()
    <input type="hidden" id="delete-news-id" name="id" />
</form>

@section Scripts {
    <script>
        async function publishNews(id) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            const res = await fetch(`/Admin/News/Publish/${id}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': token,
                    'Content-Type': 'application/json'
                }
            });

            const data = await res.json();
            if (data.success) {
                toastr.success('সংবাদ প্রকাশিত হয়েছে');
                setTimeout(() => location.reload(), 1000);
            } else {
                toastr.error('প্রকাশ করা যায়নি');
            }
        }

        async function deleteNews(id, title) {
            const result = await Swal.fire({
                title: 'সংবাদ মুছে ফেলবেন?',
                html: `<strong>"${title}"</strong><br>
                       <span class="text-muted small">এই কাজটি পূর্বাবস্থায় ফেরানো যাবে না।</span>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'মুছুন',
                cancelButtonText: 'বাতিল'
            });

            if (!result.isConfirmed) return;

            const form = document.getElementById('delete-form');
            document.getElementById('delete-news-id').value = id;
            form.action = `/Admin/News/Delete/${id}`;
            form.submit();
        }
    </script>
}