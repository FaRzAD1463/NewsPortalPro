@model CreateNewsDto
@{
    ViewData["Title"] = "নতুন সংবাদ";
}

<form asp-action="Create" asp-controller="News" asp-area="Admin"
      method="post" enctype="multipart/form-data" id="news-form">
    @Html.AntiForgeryToken()

    <div class="row g-4">

        <!-- Left: Content -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium">শিরোনাম <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control form-control-lg"
                               placeholder="সংবাদের শিরোনাম লিখুন..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">উপশিরোনাম</label>
                        <input asp-for="Subtitle" class="form-control"
                               placeholder="ঐচ্ছিক উপশিরোনাম..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">সারসংক্ষেপ</label>
                        <textarea asp-for="Summary" class="form-control" rows="3"
                                  placeholder="সংক্ষিপ্ত বিবরণ (SEO ও প্রিভিউয়ের জন্য)..."></textarea>
                    </div>
                    <div>
                        <label class="form-label fw-medium">বিষয়বস্তু <span class="text-danger">*</span></label>
                        <textarea asp-for="Content" id="content-editor" class="form-control" rows="20"></textarea>
                    </div>
                </div>
            </div>

            <!-- SEO -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h6 class="fw-bold mb-0"><i class="bi bi-search me-2 text-primary"></i>SEO সেটিংস</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label">Meta শিরোনাম (সর্বোচ্চ ১৬০ অক্ষর)</label>
                        <input asp-for="MetaTitle" class="form-control" maxlength="160" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Meta বিবরণ (সর্বোচ্চ ৩০০ অক্ষর)</label>
                        <textarea asp-for="MetaDescription" class="form-control" rows="2" maxlength="300"></textarea>
                    </div>
                    <div>
                        <label class="form-label">Meta কীওয়ার্ড</label>
                        <input asp-for="MetaKeywords" class="form-control"
                               placeholder="কমা দিয়ে আলাদা করুন" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Settings -->
        <div class="col-lg-4">

            <!-- Publish Settings -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h6 class="fw-bold mb-0"><i class="bi bi-send me-2 text-primary"></i>প্রকাশনা</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium">স্ট্যাটাস</label>
                        <select asp-for="Status" class="form-select">
                            <option value="@NewsStatus.Draft">ড্রাফট</option>
                            <option value="@NewsStatus.Published">প্রকাশিত</option>
                            <option value="@NewsStatus.Scheduled">শিডিউল</option>
                        </select>
                    </div>
                    <div class="mb-3" id="scheduled-date-row" style="display:none">
                        <label class="form-label">প্রকাশনার তারিখ ও সময়</label>
                        <input asp-for="ScheduledAt" type="datetime-local" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">বিভাগ <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select" required>
                            <option value="">বিভাগ নির্বাচন করুন</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">ট্যাগ</label>
                        <input type="text" id="tags-input" class="form-control"
                               placeholder="ট্যাগ লিখুন, Enter চাপুন" />
                        <div id="tags-container" class="mt-2 d-flex flex-wrap gap-1"></div>
                        <input type="hidden" name="Tags" id="tags-hidden" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">সংবাদের ধরন</label>
                        <select asp-for="Type" class="form-select">
                            <option value="@NewsType.Article">প্রতিবেদন</option>
                            <option value="@NewsType.Video">ভিডিও</option>
                            <option value="@NewsType.Gallery">গ্যালারি</option>
                            <option value="@NewsType.LiveBlog">লাইভ ব্লগ</option>
                        </select>
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input asp-for="IsBreaking" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">ব্রেকিং নিউজ</label>
                    </div>
                    <div class="form-check form-switch mb-2">
                        <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                        <label class="form-check-label">ফিচার্ড নিউজ</label>
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input asp-for="AllowComments" class="form-check-input" type="checkbox" checked />
                        <label class="form-check-label">মন্তব্য অনুমতি</label>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" name="Status" value="@NewsStatus.Published" class="btn btn-primary">
                            <i class="bi bi-send me-2"></i>প্রকাশ করুন
                        </button>
                        <button type="submit" name="Status" value="@NewsStatus.Draft" class="btn btn-outline-secondary">
                            <i class="bi bi-save me-2"></i>ড্রাফট সেভ করুন
                        </button>
                    </div>
                </div>
            </div>

            <!-- Featured Image -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h6 class="fw-bold mb-0"><i class="bi bi-image me-2 text-primary"></i>ফিচার্ড ইমেজ</h6>
                </div>
                <div class="card-body p-4">
                    <div class="image-upload-area mb-3" id="image-drop-zone">
                        <div id="image-preview-container">
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-cloud-upload fs-2"></i>
                                <p class="small mt-2">ছবি টেনে আনুন বা ক্লিক করুন</p>
                            </div>
                        </div>
                        <input type="file" name="featuredImage" id="featured-image-input"
                               accept="image/*" class="d-none" />
                        <input type="hidden" asp-for="FeaturedImageUrl" />
                    </div>
                    <button type="button" class="btn btn-outline-primary btn-sm w-100"
                            onclick="document.getElementById('featured-image-input').click()">
                        <i class="bi bi-upload me-2"></i>ছবি আপলোড করুন
                    </button>

                    <div class="mt-3">
                        <input asp-for="FeaturedImageAlt" class="form-control form-control-sm mb-2"
                               placeholder="Alt টেক্সট (SEO)" />
                        <input asp-for="FeaturedImageCaption" class="form-control form-control-sm"
                               placeholder="ছবির ক্যাপশন" />
                    </div>
                </div>
            </div>

            <!-- Video URL -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h6 class="fw-bold mb-0"><i class="bi bi-play-circle me-2 text-primary"></i>ভিডিও</h6>
                </div>
                <div class="card-body p-4">
                    <input asp-for="VideoUrl" class="form-control"
                           placeholder="YouTube/ভিমিও এম্বেড URL" />
                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.10.5/sweetalert2.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.10.5/sweetalert2.min.css" rel="stylesheet" />
    <script>
        // CKEditor
        (async function() {
            if (typeof ClassicEditor !== 'undefined') {
                const editor = await ClassicEditor.create(document.getElementById('content-editor'), {
                    toolbar: ['heading','|','bold','italic','underline','strikethrough','|',
                              'bulletedList','numberedList','blockQuote','|',
                              'link','insertTable','mediaEmbed','|','undo','redo'],
                    language: 'bn'
                });
            }
        })();

        // Tag input
        const tags = [];
        const tagsInput = document.getElementById('tags-input');
        tagsInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' || e.key === ',') {
                e.preventDefault();
                const val = this.value.trim();
                if (val && !tags.includes(val)) {
                    tags.push(val);
                    renderTags();
                    this.value = '';
                }
            }
        });

        function renderTags() {
            const container = document.getElementById('tags-container');
            container.innerHTML = tags.map((t, i) =>
                `<span class="badge bg-secondary">
                    ${t}
                    <i class="bi bi-x ms-1" style="cursor:pointer" onclick="removeTag(${i})"></i>
                </span>`
            ).join('');
            document.getElementById('tags-hidden').value = JSON.stringify(tags);
        }

        function removeTag(i) { tags.splice(i, 1); renderTags(); }

        // Scheduled date toggle
        document.querySelector('[name="Status"]')?.addEventListener('change', function() {
            document.getElementById('scheduled-date-row').style.display =
                this.value === '@NewsStatus.Scheduled' ? 'block' : 'none';
        });

        // Image preview
        document.getElementById('featured-image-input').addEventListener('change', function() {
            const file = this.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('image-preview-container').innerHTML =
                    `<img src="${e.target.result}" class="img-fluid rounded" />`;
            };
            reader.readAsDataURL(file);
        });

        // Drag and drop
        const dropZone = document.getElementById('image-drop-zone');
        dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('drag-over');
            const file = e.dataTransfer.files[0];
            if (file) {
                document.getElementById('featured-image-input').files = e.dataTransfer.files;
                document.getElementById('featured-image-input').dispatchEvent(new Event('change'));
            }
        });
        dropZone.addEventListener('click', () =>
            document.getElementById('featured-image-input').click());
    </script>
}