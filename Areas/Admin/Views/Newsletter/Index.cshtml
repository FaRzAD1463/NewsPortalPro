@using NewsPortalPro.DTOs
@using NewsPortalPro.Models
@model List<NewsPortalPro.Models.Newsletter>
@{
    ViewData["Title"] = "নিউজলেটার";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">নিউজলেটার</h4>
        <small class="text-muted">
            <i class="bi bi-people me-1"></i>
            মোট সক্রিয় সাবস্ক্রাইবার: <strong>@ViewBag.SubscriberCount</strong>
        </small>
    </div>
    <a href="/Admin/Newsletter/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>নতুন নিউজলেটার
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>বিষয়</th>
                        <th>স্ট্যাটাস</th>
                        <th>প্রাপক</th>
                        <th>পাঠানোর তারিখ</th>
                        <th>তৈরির তারিখ</th>
                        <th>অ্যাকশন</th>
                    </tr>

                </thead>
                <tbody>
                    @foreach (var nl in Model)
                    {
                        <tr>
                            <td class="fw-medium">@nl.Subject</td>
                            <td>
                                @if (nl.IsSent)
                                {
                                    <span class="badge bg-success">পাঠানো হয়েছে</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">অপেক্ষারত</span>
                                }
                            </td>
                            <td>
                                @if (nl.IsSent)
                                {
                                    <span class="badge bg-primary">@nl.RecipientCount</span>
                                }
                                else
                                {

                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td><small class="text-muted">@(nl.SentAt?.ToString("dd/MM/yy HH:mm") ?? "-")</small></td>
                            <td><small class="text-muted">@nl.CreatedAt.ToString("dd/MM/yy")</small></td>
                            <td>
                                <div class="d-flex gap-2">
                                    @if (!nl.IsSent)
                                    {
                                        <form asp-action="Send" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@nl.Id" />
                                            <button type="submit" class="btn btn-sm btn-success"
                                                    onclick="return confirm('পাঠাতে নিশ্চিত?')">
                                                <i class="bi bi-send me-1"></i>পাঠান
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@nl.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>