@{
    ViewData["Title"] = "নতুন নিউজলেটার";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">নতুন নিউজলেটার</h4>
    <a href="/Admin/Newsletter"
       class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>ফিরে যান
    </a>
</div>

<form asp-action="Create"
      asp-controller="Newsletter"
      asp-area="Admin" method="post">
    @Html.AntiForgeryToken()

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            বিষয় <span class="text-danger">*</span>
                        </label>
                        <input type="text" name="subject"
                               class="form-control form-control-lg"
                               placeholder="নিউজলেটারের বিষয় লিখুন..."
                               required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium">
                            বিষয়বস্তু
                            <span class="text-danger">*</span>
                        </label>
                        <textarea name="body"
                                  id="newsletter-editor"
                                  class="form-control"
                                  rows="20" required>
                        </textarea>
                    </div>

                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        সংরক্ষণের পর Index পাতা থেকে পাঠান।
                        পাঠানো হলে ফিরিয়ে আনা যাবে না।
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary px-4">
                            <i class="bi bi-save me-2"></i>
                            সংরক্ষণ করুন
                        </button>
                        <a href="/Admin/Newsletter"
                           class="btn btn-outline-secondary">
                            বাতিল
                        </a>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent fw-medium">
                    টিপস
                </div>
                <div class="card-body small text-muted">
                    <p>
                        <i class="bi bi-check-circle
                        text-success me-2"></i>
                        সংক্ষিপ্ত ও আকর্ষণীয় বিষয় লিখুন
                    </p>
                    <p>
                        <i class="bi bi-check-circle
                        text-success me-2"></i>
                        ছবি যোগ করে কন্টেন্ট আকর্ষণীয় করুন
                    </p>
                    <p>
                        <i class="bi bi-check-circle
                        text-success me-2"></i>
                        আনসাবস্ক্রাইব লিঙ্ক স্বয়ংক্রিয়ভাবে যোগ হবে
                    </p>
                    <p class="mb-0">
                        <i class="bi bi-info-circle
                        text-primary me-2"></i>
                        SMTP সেটিংস না থাকলে ইমেইল যাবে না
                    </p>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.3/tinymce.min.js"></script>
    <script>
        tinymce.init({
        selector: '#newsletter-editor',
        height:   400,
        menubar:  false,
        plugins: [
        'advlist','autolink','lists','link','image',
        'charmap','preview','code','table','help'
        ],
        toolbar:
        'undo redo | blocks | ' +
        'bold italic underline | ' +
        'alignleft aligncenter alignright | ' +
        'bullist numlist | link image | ' +
        'forecolor backcolor | code | help',
        content_style:
        'body{font-family:Noto Sans Bengali,sans-serif;' +
        'font-size:15px;line-height:1.7;color:#222;' +
        'padding:12px}p{margin-bottom:12px}'
        });
    </script>
}