@{
    ViewData["Title"] = "নতুন নিউজলেটার";
}

<form asp-action="Create" asp-controller="Newsletter" asp-area="Admin" method="post">
    @Html.AntiForgeryToken()

    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">নতুন নিউজলেটার রচনা করুন</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-medium">বিষয় <span class="text-danger">*</span></label>
                        <input type="text" name="subject" class="form-control form-control-lg"
                               placeholder="নিউজলেটারের বিষয় লিখুন..." required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-medium">বিষয়বস্তু <span class="text-danger">*</span></label>
                        <textarea name="body" id="newsletter-editor" class="form-control"
                                  rows="20" required></textarea>
                    </div>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        পাঠানোর আগে নিশ্চিত করুন। একবার পাঠালে ফিরিয়ে আনা যাবে না।
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-save me-2"></i>সংরক্ষণ করুন
                        </button>
                        <a href="/Admin/Newsletter" class="btn btn-outline-secondary">বাতিল</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>