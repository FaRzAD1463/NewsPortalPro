@model UpdateCategoryDto
@{
    ViewData["Title"] = "বিভাগ সম্পাদনা";
}

<form asp-action="Edit" asp-controller="Category" asp-area="Admin"
      asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">বিভাগ সম্পাদনা</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label fw-medium">নাম <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-medium">রঙ কোড</label>
                            <div class="input-group">
                                <input asp-for="ColorCode" class="form-control" id="edit-color-input" />
                                <input type="color" class="form-control form-control-color"
                                       id="edit-color-picker"
                                       value="@(Model.ColorCode ?? "#6c757d")"
                                       style="max-width:50px" />
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium">বিবরণ</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">মূল বিভাগ</label>
                            <select asp-for="ParentId" asp-items="ViewBag.Parents" class="form-select">
                                <option value="">কোনো মূল বিভাগ নেই</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">ক্রম</label>
                            <input asp-for="DisplayOrder" type="number" class="form-control" min="0" />
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label class="form-check-label fw-medium">সক্রিয়</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input asp-for="ShowInMenu" class="form-check-input" type="checkbox" />
                                <label class="form-check-label fw-medium">মেনুতে দেখান</label>
                            </div>
                        </div>
                        <div class="col-12 mt-2">
                            <h6 class="fw-bold text-muted mb-3">SEO সেটিংস</h6>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Meta শিরোনাম</label>
                            <input asp-for="MetaTitle" class="form-control" maxlength="160" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Meta বিবরণ</label>
                            <textarea asp-for="MetaDescription" class="form-control"
                                      rows="2" maxlength="300"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Meta কীওয়ার্ড</label>
                            <input asp-for="MetaKeywords" class="form-control" />
                        </div>
                        <div class="col-12 pt-2">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary px-4">
                                    <i class="bi bi-save me-2"></i>আপডেট করুন
                                </button>
                                <a href="/Admin/Category" class="btn btn-outline-secondary">বাতিল</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        const inp = document.getElementById('edit-color-input');
        const pic = document.getElementById('edit-color-picker');
        pic.addEventListener('input', () => inp.value = pic.value);
        inp.addEventListener('input', () => {
            if (/^#[0-9A-Fa-f]{6}$/.test(inp.value)) pic.value = inp.value;
        });
    </script>
}