@using NewsPortalPro.DTOs
@using NewsPortalPro.Models
@using NewsPortalPro.ViewModels
@using NewsPortalPro.Helpers
@model List<NewsPortalPro.DTOs.CategoryWithCountDto>
@{
    ViewData["Title"] = "বিভাগ ব্যবস্থাপনা";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">বিভাগ তালিকা</h4>
    <a href="/Admin/Category/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>নতুন বিভাগ
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>নাম</th>
                        <th>স্লাগ</th>
                        <th>রঙ</th>
                        <th>সংবাদ</th>
                        <th>মেনুতে</th>
                        <th>স্ট্যাটাস</th>
                        <th>অ্যাকশন</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-medium">@cat.Name</span>
                                @if (cat.ParentName != null)
                                {
                                    <small class="text-muted d-block">→ @cat.ParentName</small>
                                }
                            </td>
                            <td><code class="small">@cat.Slug</code></td>
                            <td>
                                <span class="d-inline-block rounded" style="width:24px;height:24px;background:@cat.ColorCode"></span>
                            </td>
                            <td><span class="badge bg-primary">@cat.NewsCount</span></td>
                            <td>
                                @if (cat.ShowInMenu)
                                {
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                }
                                else
                                {
                                    <i class="bi bi-x-circle text-muted"></i>
                                }
                            </td>
                            <td>
                                <span class="badge @(cat.IsActive ? "bg-success" : "bg-secondary")">
                                    @(cat.IsActive ? "সক্রিয়" : "নিষ্ক্রিয়")
                                </span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="/Admin/Category/Edit/@cat.Id" class="btn btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button class="btn btn-outline-danger"
                                            onclick="deleteCategory(@cat.Id, '@cat.Name')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function deleteCategory(id, name) {
            const result = await Swal.fire({
                title: 'বিভাগ মুছুন?',
                html: `<strong>${name}</strong> বিভাগটি মুছে ফেলতে চান?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'মুছুন',
                cancelButtonText: 'বাতিল'
            });
            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = `/Admin/Category/Delete/${id}`;
                form.innerHTML = `<input type="hidden" name="__RequestVerificationToken"
                    value="${$('input[name=__RequestVerificationToken]').val()}" />`;
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}