@using NewsPortalPro.Models
@model List<Epaper>
@{
    ViewData["Title"] = "ই-পেপার ব্যবস্থাপনা";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">ই-পেপার ব্যবস্থাপনা</h4>
    <a href="/Admin/Epaper/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>নতুন ই-পেপার
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-newspaper fs-1 text-muted"></i>
        <p class="text-muted mt-3">কোনো ই-পেপার নেই।</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>শিরোনাম</th>
                        <th>তারিখ</th>
                        <th>স্ট্যাটাস</th>
                        <th class="text-center">অ্যাকশন</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-medium">@e.Title</div>
                                <small class="text-muted">@e.PdfUrl</small>
                            </td>
                            <td class="text-muted small">
                                @e.PublishedDate.ToString("dd MMM yyyy")
                            </td>
                            <td>
                                @if (e.IsActive)
                                {
                                    <span class="badge bg-success">সক্রিয়</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        নিষ্ক্রিয়
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1
                                    justify-content-center">
                                    <a href="@e.PdfUrl" target="_blank"
                                       class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (!e.IsActive)
                                    {
                                        <button class="btn btn-outline-success
                                            btn-sm"
                                                data-id="@e.Id"
                                                onclick="setActive(@e.Id)">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    }
                                    <form method="post"
                                          action="/Admin/Epaper/Delete/@e.Id"
                                          style="display:inline"
                                          onsubmit="return confirmDelete(this)">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-outline-danger
                                            btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script>
        async function setActive(id) {
            const token = document.querySelector(
                'input[name="__RequestVerificationToken"]')?.value;
            const fd = new FormData();
            fd.append('__RequestVerificationToken', token);

            const res = await fetch(`/Admin/Epaper/SetActive/${id}`,
                { method: 'POST', body: fd });
            if (res.ok) {
                toastr.success('সক্রিয় করা হয়েছে');
                setTimeout(() => location.reload(), 800);
            }
        }
    </script>
}