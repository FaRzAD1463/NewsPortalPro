@using NewsPortalPro.DTOs
@using NewsPortalPro.Models
@model List<NewsPortalPro.Models.Photo>
@{
    ViewData["Title"] = "মিডিয়া লাইব্রেরি";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">মিডিয়া লাইব্রেরি</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" onclick="document.getElementById('bulk-upload').click()">
            <i class="bi bi-cloud-upload me-2"></i>আপলোড করুন
        </button>
        <input type="file" id="bulk-upload" accept="image/*" multiple class="d-none" />
    </div>
</div>

<!-- Upload Area -->
<div id="upload-drop-zone" class="upload-zone mb-4 p-5 text-center border-2 rounded"
     style="border: 2px dashed #dee2e6; cursor:pointer">
    <i class="bi bi-cloud-upload fs-1 text-muted"></i>
    <p class="text-muted mt-2 mb-0">ছবি টেনে আনুন বা ক্লিক করে আপলোড করুন</p>
</div>

<!-- Upload Progress -->
<div id="upload-progress-container" class="mb-4 d-none">
    <div class="progress">
        <div id="upload-progress-bar" class="progress-bar progress-bar-striped progress-bar-animated"
             style="width:0%"></div>
    </div>
</div>

<!-- Media Grid -->
<div class="row g-3" id="media-grid">
    @foreach (var photo in Model)
    {
        <div class="col-6 col-md-3 col-lg-2" id="photo-@photo.Id">
            <div class="media-item position-relative rounded overflow-hidden shadow-sm"
                 style="aspect-ratio:4/3">
                <img src="@(photo.ThumbnailUrl ?? photo.ImageUrl)"
                     alt="@photo.AltText"
                     class="w-100 h-100"
                     style="object-fit:cover" loading="lazy" />
                <div class="media-overlay position-absolute inset-0 d-flex flex-column
                                justify-content-between p-2 opacity-0">
                    <div class="d-flex justify-content-end">
                        <button class="btn btn-danger btn-sm rounded-circle"
                                onclick="deletePhoto(@photo.Id)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                    <div>
                        <button class="btn btn-light btn-sm w-100"
                                onclick="copyUrl('@photo.ImageUrl')">
                            <i class="bi bi-clipboard me-1"></i>URL কপি
                        </button>
                    </div>
                </div>
            </div>
            <small class="text-muted d-block mt-1 text-truncate">
                @photo.UploadedAt.ToString("dd/MM/yy")
            </small>
        </div>
    }
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.Page ? "active" : "")">
                    <a class="page-link" href="?page=@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@section Styles {
    <style>
        .media-item:hover .media-overlay {
            opacity: 1 !important;
            transition: opacity .2s;
        }

        .media-overlay {
            background: rgba(0,0,0,.5);
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            transition: opacity .2s;
        }

        .inset-0 {
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
        }
    </style>
}

@section Scripts {
    <script>
        const token = $('input[name="__RequestVerificationToken"]').val();

        // Drop zone
        const dropZone = document.getElementById('upload-drop-zone');
        dropZone.addEventListener('click', () => document.getElementById('bulk-upload').click());
        dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-primary'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-primary'));
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.classList.remove('border-primary');
            uploadFiles(e.dataTransfer.files);
        });

        document.getElementById('bulk-upload').addEventListener('change', function () {
            uploadFiles(this.files);
        });

        async function uploadFiles(files) {
            const progressContainer = document.getElementById('upload-progress-container');
            const progressBar = document.getElementById('upload-progress-bar');
            progressContainer.classList.remove('d-none');

            for (let i = 0; i < files.length; i++) {
                const pct = Math.round(((i + 1) / files.length) * 100);
                progressBar.style.width = pct + '%';

                const formData = new FormData();
                formData.append('file', files[i]);
                formData.append('__RequestVerificationToken', token);

                try {
                    const res = await fetch('/Admin/Media/Upload', { method: 'POST', body: formData });
                    const data = await res.json();
                    if (data.success) {
                        const col = `
                            <div class="col-6 col-md-3 col-lg-2" id="photo-${data.id}">
                                <div class="media-item position-relative rounded overflow-hidden shadow-sm"
                                     style="aspect-ratio:4/3">
                                    <img src="${data.thumbnail || data.url}" class="w-100 h-100"
                                         style="object-fit:cover" loading="lazy" />
                                    <div class="media-overlay position-absolute inset-0 d-flex flex-column
                                                justify-content-between p-2 opacity-0">
                                        <div class="d-flex justify-content-end">
                                            <button class="btn btn-danger btn-sm rounded-circle"
                                                    onclick="deletePhoto(${data.id})">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                        <div>
                                            <button class="btn btn-light btn-sm w-100"
                                                    onclick="copyUrl('${data.url}')">
                                                <i class="bi bi-clipboard me-1"></i>URL কপি
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>`;
                        document.getElementById('media-grid').insertAdjacentHTML('afterbegin', col);
                        toastr.success('আপলোড সফল হয়েছে');
                    }
                } catch (e) {
                    toastr.error('আপলোড ব্যর্থ হয়েছে');
                }
            }

            progressContainer.classList.add('d-none');
            progressBar.style.width = '0%';
        }

        async function deletePhoto(id) {
            const result = await Swal.fire({
                title: 'ছবি মুছুন?', icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#dc3545',
                confirmButtonText: 'মুছুন', cancelButtonText: 'বাতিল'
            });
            if (!result.isConfirmed) return;

            const res = await fetch(`/Admin/Media/Delete/${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });
            if (res.ok) {
                document.getElementById(`photo-${id}`)?.remove();
                toastr.success('ছবি মুছে ফেলা হয়েছে');
            }
        }

        function copyUrl(url) {
            navigator.clipboard.writeText(url);
            toastr.info('URL কপি হয়েছে');
        }
    </script>
}