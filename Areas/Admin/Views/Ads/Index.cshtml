@using NewsPortalPro.DTOs
@using NewsPortalPro.Models
@model List<AdvertisementDto>
@{
    ViewData["Title"] = "বিজ্ঞাপন ব্যবস্থাপনা";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">বিজ্ঞাপন ব্যবস্থাপনা</h4>
    <a href="/Admin/Ads/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>নতুন বিজ্ঞাপন
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-megaphone fs-1 text-muted"></i>
        <p class="text-muted mt-3">কোনো বিজ্ঞাপন নেই।</p>
        <a href="/Admin/Ads/Create" class="btn btn-primary btn-sm">
            প্রথম বিজ্ঞাপন তৈরি করুন
        </a>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:80px">ছবি</th>
                        <th>শিরোনাম</th>
                        <th style="width:120px">পজিশন</th>
                        <th style="width:90px">স্ট্যাটাস</th>
                        <th style="width:90px">ইম্প্রেশন</th>
                        <th style="width:70px">ক্লিক</th>
                        <th style="width:60px">CTR</th>
                        <th style="width:130px"
                            class="text-center">অ্যাকশন</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ad in Model.OrderBy(
                        a => a.DisplayOrder))
                    {
                        <tr>
                            <!-- Image / HTML badge -->
                            <td>
                                @if (!string.IsNullOrEmpty(ad.ImageUrl))
                                {
                                    <img src="@ad.ImageUrl"
                                         class="rounded"
                                         style="width:64px;height:44px;
                                    object-fit:cover" />
                                }
                                else if (!string.IsNullOrEmpty(
                                    ad.HtmlCode))
                                {
                                    <span class="badge bg-info">HTML</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        —
                                    </span>
                                }
                            </td>

                            <!-- Title + URL -->
                            <td>
                                <div class="fw-medium small">
                                    @ad.Title
                                </div>
                                @if (!string.IsNullOrEmpty(ad.TargetUrl))
                                {
                                    <small class="text-muted text-truncate
                                        d-block"
                                           style="max-width:250px">
                                        @ad.TargetUrl
                                    </small>
                                }
                                @if (ad.StartDate.HasValue ||
                                     ad.EndDate.HasValue)
                                {
                                    <small class="text-muted">
                                        @(ad.StartDate?.ToString("dd/MM/yy")
                                          ?? "—")
                                        →
                                        @(ad.EndDate?.ToString("dd/MM/yy")
                                          ?? "∞")
                                    </small>
                                }
                            </td>

                            <!-- Position -->
                            <td>
                                <span class="badge bg-primary
                                    rounded-pill"
                                      style="font-size:11px">
                                    @(ad.Position switch
                                    {
                                        AdPosition.Header => "হেডার",
                                        AdPosition.Sidebar => "সাইডবার",
                                        AdPosition.Footer => "ফুটার",
                                        AdPosition.InArticle => "আর্টিকেল",
                                        AdPosition.Popup => "পপআপ",
                                        AdPosition.BelowTitle => "শিরোনামের নিচে",
                                        _ => ad.Position.ToString()
                                    })
                                </span>
                            </td>

                            <!-- Status -->
                            <td>
                                @if (ad.IsActive)
                                {
                                    <span class="badge bg-success"
                                          style="font-size:11px">
                                        সক্রিয়
                                    </span>
                                }
                                else if (ad.Status == AdStatus.Expired)
                                {
                                    <span class="badge bg-warning
                                        text-dark"
                                          style="font-size:11px">
                                        মেয়াদ শেষ
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"
                                          style="font-size:11px">
                                        নিষ্ক্রিয়
                                    </span>
                                }
                            </td>

                            <!-- Impression -->
                            <td class="text-muted small text-center">
                                @ad.ImpressionCount.ToString("N0")
                            </td>

                            <!-- Click -->
                            <td class="text-muted small text-center">
                                @ad.ClickCount.ToString("N0")
                            </td>

                            <!-- CTR -->
                            <td class="text-muted small text-center">
                                @ad.Ctr%
                            </td>

                            <!-- Actions -->
                            <td class="text-center">
                                <div class="d-flex gap-1
                                    justify-content-center">
                                    <!-- Toggle status -->
                                    <button class="btn btn-sm
                                        @(ad.IsActive
                                                ? "btn-outline-warning"
                                                : "btn-outline-success")"
                                            onclick="toggleStatus(@ad.Id)"
                                            title="@(ad.IsActive
                                                                                            ? "নিষ্ক্রিয় করুন"
                                                                                            : "সক্রিয় করুন")">
                                        <i class="bi @(ad.IsActive
                                                                                       ? "bi-pause-circle"
                                                                                       : "bi-play-circle")"></i>
                                    </button>

                                    <!-- Edit -->
                                    <a href="/Admin/Ads/Edit/@ad.Id"
                                       class="btn btn-outline-primary
                                        btn-sm"
                                       title="সম্পাদনা">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <!-- Delete -->
                                    <button class="btn btn-outline-danger
                                        btn-sm btn-delete-ad"
                                            data-id="@ad.Id"
                                            title="মুছুন">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<form id="delete-ad-form" method="post" style="display:none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script>
        var _token = document.querySelector(
            'input[name="__RequestVerificationToken"]')?.value ?? '';

        // ── Toggle status ──────────────────────────────────────
        async function toggleStatus(id) {
            var fd = new FormData();
            fd.append('__RequestVerificationToken', _token);
            try {
                var res  = await fetch(
                    '/Admin/Ads/ToggleStatus/' + id,
                    { method: 'POST', body: fd });
                var data = await res.json();
                if (data.success) {
                    toastr.success('স্ট্যাটাস পরিবর্তন হয়েছে');
                    setTimeout(function() { location.reload(); }, 600);
                }
            } catch {
                toastr.error('নেটওয়ার্ক ত্রুটি');
            }
        }

        // ── Delete ─────────────────────────────────────────────
        document.addEventListener('click', function(e) {
            var btn = e.target.closest('.btn-delete-ad');
            if (!btn) return;
            e.preventDefault();
            var id = btn.dataset.id;

            Swal.fire({
                title:              'বিজ্ঞাপন মুছে ফেলবেন?',
                text:               'এই কাজটি পূর্বাবস্থায় ফেরানো যাবে না।',
                icon:               'warning',
                showCancelButton:   true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor:  '#6c757d',
                confirmButtonText:  'মুছুন',
                cancelButtonText:   'বাতিল'
            }).then(async function(result) {
                if (!result.isConfirmed) return;
                var fd = new FormData();
                fd.append('__RequestVerificationToken', _token);
                var res = await fetch(
                    '/Admin/Ads/Delete/' + id,
                    { method: 'POST', body: fd });
                if (res.ok) {
                    toastr.success('বিজ্ঞাপন মুছে ফেলা হয়েছে');
                    btn.closest('tr')?.remove();
                } else {
                    toastr.error('মুছতে ব্যর্থ হয়েছে');
                }
            });
        });
    </script>
}