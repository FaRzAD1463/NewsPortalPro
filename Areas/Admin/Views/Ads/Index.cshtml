@using NewsPortalPro.Models
@using NewsPortalPro.DTOs
@model List<AdvertisementDto>
@{
    ViewData["Title"] = "বিজ্ঞাপন ব্যবস্থাপনা";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">বিজ্ঞাপন তালিকা</h4>
    <a href="/Admin/Ads/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>নতুন বিজ্ঞাপন
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ছবি</th>
                        <th>শিরোনাম</th>
                        <th>পজিশন</th>
                        <th>স্ট্যাটাস</th>
                        <th>ইম্প্রেশন</th>
                        <th>ক্লিক</th>
                        <th>CTR</th>
                        <th>মেয়াদ</th>
                        <th>অ্যাকশন</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ad in Model)
                    {
                        var ctr = ad.ImpressionCount > 0
                        ? ((double)ad.ClickCount / ad.ImpressionCount * 100).ToString("F2") + "%"
                        : "0%";
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(ad.ImageUrl))
                                {
                                    <img src="@ad.ImageUrl" alt="@ad.Title"
                                         class="rounded" width="60" height="40"
                                         style="object-fit:cover" />
                                }
                                else
                                {
                                    <span class="badge bg-secondary">HTML</span>
                                }
                            </td>
                            <td>
                                <div class="fw-medium">@ad.Title</div>
                                @if (!string.IsNullOrEmpty(ad.TargetUrl))
                                {
                                    <small class="text-muted text-truncate d-block" style="max-width:200px">
                                        @ad.TargetUrl
                                    </small>
                                }
                            </td>
                            <td><span class="badge bg-info text-dark">@ad.Position</span></td>
                            <td>
                                <span class="badge @(ad.Status == AdStatus.Active ? "bg-success" : "bg-secondary")">
                                    @ad.Status
                                </span>
                            </td>
                            <td>@ad.ImpressionCount.ToString("N0")</td>
                            <td>@ad.ClickCount.ToString("N0")</td>
                            <td><span class="fw-medium text-primary">@ctr</span></td>
                            <td>
                                <small class="text-muted">
                                    @(ad.StartDate?.ToString("dd/MM") ?? "∞") →
                                    @(ad.EndDate?.ToString("dd/MM") ?? "∞")
                                </small>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="/Admin/Ads/Edit/@ad.Id" class="btn btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@ad.Id" />
                                        <button type="submit" class="btn btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>