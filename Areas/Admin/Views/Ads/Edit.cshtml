@using NewsPortalPro.Models
@using NewsPortalPro.DTOs
@model UpdateAdDto
@{
    ViewData["Title"] = "বিজ্ঞাপন সম্পাদনা";
}

<form asp-action="Edit" asp-controller="Ads" asp-area="Admin"
      asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">বিজ্ঞাপন সম্পাদনা</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-medium">শিরোনাম</label>
                            <input asp-for="Title" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">পজিশন</label>
                            <select asp-for="Position" class="form-select">
                                @foreach (var pos in Enum.GetValues<NewsPortalPro.Models.AdPosition>())
                                {
                                    <option value="@pos" selected="@(Model.Position == pos)">@pos</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium">স্ট্যাটাস</label>
                            <select asp-for="Status" class="form-select">
                                @foreach (var s in Enum.GetValues<NewsPortalPro.Models.AdStatus>())
                                {
                                    <option value="@s" selected="@(Model.Status == s)">@s</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" class="img-fluid rounded mb-2"
                                     style="max-height:80px" alt="Current" />
                            }
                            <label class="form-label fw-medium">ছবির URL</label>
                            <input asp-for="ImageUrl" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium">গন্তব্য URL</label>
                            <input asp-for="TargetUrl" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium">HTML কোড</label>
                            <textarea asp-for="HtmlCode" class="form-control font-monospace" rows="4"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">শুরুর তারিখ</label>
                            <input asp-for="StartDate" type="datetime-local" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">শেষের তারিখ</label>
                            <input asp-for="EndDate" type="datetime-local" class="form-control" />
                        </div>
                        <div class="col-12 pt-2">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary px-4">
                                    <i class="bi bi-save me-2"></i>আপডেট করুন
                                </button>
                                <a href="/Admin/Ads" class="btn btn-outline-secondary">বাতিল</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>