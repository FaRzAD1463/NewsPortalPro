@using NewsPortalPro.DTOs
@using NewsPortalPro.Models
@model CreateAdDto
@{
    ViewData["Title"] = "নতুন বিজ্ঞাপন";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">নতুন বিজ্ঞাপন তৈরি</h4>
    <a href="/Admin/Ads" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>ফিরে যান
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <form method="post" enctype="multipart/form-data"
              asp-action="Create">
            @Html.AntiForgeryToken()

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            শিরোনাম <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title"
                               class="form-control"
                               placeholder="বিজ্ঞাপনের নাম"
                               required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            পজিশন <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Position"
                                class="form-select">
                            @if (ViewBag.Positions is
                                 List<Microsoft.AspNetCore.Mvc.Rendering
                                 .SelectListItem> positions)
                            {
                                @foreach (var p in positions)
                                {
                                    <option value="@p.Value">
                                        @p.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            স্ট্যাটাস
                        </label>
                        <select asp-for="Status" class="form-select">
                            @if (ViewBag.Statuses is
                                 List<Microsoft.AspNetCore.Mvc.Rendering
                                 .SelectListItem> statuses)
                            {
                                @foreach (var s in statuses)
                                {
                                    <option value="@s.Value">
                                        @s.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            টার্গেট URL
                        </label>
                        <input asp-for="TargetUrl"
                               class="form-control"
                               placeholder="https://example.com" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            বিজ্ঞাপনের ছবি
                        </label>
                        <input type="file" name="imageFile"
                               class="form-control mb-2"
                               accept="image/*"
                               onchange="previewAdImage(this)" />
                        <img id="ad-preview"
                             src="" class="img-fluid rounded d-none"
                             style="max-height:120px;
                        object-fit:contain" />
                        <input asp-for="ImageUrl"
                               class="form-control mt-2"
                               placeholder="অথবা সরাসরি URL দিন" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium">
                            HTML কোড
                            <small class="text-muted fw-normal">
                                (Google AdSense বা কাস্টম কোড)
                            </small>
                        </label>
                        <textarea asp-for="HtmlCode"
                                  class="form-control font-monospace"
                                  rows="6"
                                  placeholder="&lt;script&gt; বা &lt;ins&gt; কোড এখানে পেস্ট করুন">
                        </textarea>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small">
                                শুরুর তারিখ
                            </label>
                            <input asp-for="StartDate"
                                   type="date"
                                   class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">
                                শেষ তারিখ
                            </label>
                            <input asp-for="EndDate"
                                   type="date"
                                   class="form-control" />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small">
                                ডিসপ্লে অর্ডার
                            </label>
                            <input asp-for="DisplayOrder"
                                   type="number"
                                   class="form-control"
                                   min="0" value="0" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">
                                বিভাগ (ঐচ্ছিক)
                            </label>
                            <select asp-for="CategoryId"
                                    class="form-select">
                                <option value="">
                                    সব বিভাগ
                                </option>
                                @if (ViewBag.Categories is
                                     List<Microsoft.AspNetCore.Mvc
                                     .Rendering.SelectListItem> cats)
                                {
                                    @foreach (var c in cats)
                                    {
                                        <option value="@c.Value">
                                            @c.Text
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>
                            তৈরি করুন
                        </button>
                        <a href="/Admin/Ads"
                           class="btn btn-outline-secondary">
                            বাতিল
                        </a>
                    </div>

                </div>
            </div>
        </form>
    </div>

    <!-- Tips sidebar -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-medium">
                <i class="bi bi-info-circle me-2 text-primary"></i>
                পজিশন গাইড
            </div>
            <div class="card-body small text-muted">
                <p><strong>হেডার:</strong> সাইটের শীর্ষে</p>
                <p><strong>সাইডবার:</strong> ডান পাশে</p>
                <p><strong>ফুটার:</strong> সাইটের নিচে</p>
                <p><strong>আর্টিকেল:</strong> সংবাদের মধ্যে</p>
                <p>
                    <strong>শিরোনামের নিচে:</strong>
                    শিরোনামের পরে
                </p>
                <p class="mb-0">
                    <strong>পপআপ:</strong>
                    ভাসমান উইন্ডো
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewAdImage(input) {
            var preview = document.getElementById('ad-preview');
            if (!preview || !input.files || !input.files[0]) return;
            var reader = new FileReader();
            reader.onload = function(e) {
                preview.src = e.target.result;
                preview.classList.remove('d-none');
            };
            reader.readAsDataURL(input.files[0]);
        }
    </script>
}